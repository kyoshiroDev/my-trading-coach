{
  "name": "app-mytradingcoach",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "mtc",
  "sourceRoot": "apps/app-mytradingcoach/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/app-mytradingcoach",
        "browser": "apps/app-mytradingcoach/src/main.ts",
        "tsConfig": "apps/app-mytradingcoach/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/app-mytradingcoach/public"
          }
        ],
        "styles": ["apps/app-mytradingcoach/src/styles.css"]
      },
      "configurations": {
        "local": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "apps/app-mytradingcoach/src/environments/environment.ts",
              "with": "apps/app-mytradingcoach/src/environments/environment.production.ts"
            }
          ],
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "12kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "fileReplacements": [
            {
              "replace": "apps/app-mytradingcoach/src/environments/environment.ts",
              "with": "apps/app-mytradingcoach/src/environments/environment.dev.ts"
            }
          ],
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "development"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "buildTarget": "app-mytradingcoach:build:local"
      },
      "configurations": {
        "local": {
          "buildTarget": "app-mytradingcoach:build:local"
        },
        "production": {
          "buildTarget": "app-mytradingcoach:build:production"
        },
        "development": {
          "buildTarget": "app-mytradingcoach:build:development"
        }
      },
      "defaultConfiguration": "local"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "apps/app-mytradingcoach/vitest.config.ts"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "app-mytradingcoach:build",
        "port": 4200,
        "staticFilePath": "dist/apps/app-mytradingcoach/browser",
        "spa": true
      }
    }
  }
}
