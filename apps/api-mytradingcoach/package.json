{
  "name": "@org/api-mytradingcoach",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "api-mytradingcoach",
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run --config=vitest.config.ts",
          "cwd": "apps/api-mytradingcoach"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/api-mytradingcoach"
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/api-mytradingcoach/dist/package.json",
          "{workspaceRoot}/apps/api-mytradingcoach/dist/package-lock.json"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/api-mytradingcoach/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "api-mytradingcoach:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "api-mytradingcoach:build:development"
          },
          "production": {
            "buildTarget": "api-mytradingcoach:build:production"
          }
        }
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.71.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.14",
    "resend": "^6.10.0",
    "rxjs": "^7.8.2",
    "stripe": "^22.0.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.17",
    "@swc/core": "1.15.8",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  }
}
