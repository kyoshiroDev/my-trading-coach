{
  "name": "landing-mytradingcoach",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/landing-mytradingcoach/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro dev --port 4321",
        "cwd": "apps/landing-mytradingcoach"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro build",
        "cwd": "apps/landing-mytradingcoach"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro preview --port 4321",
        "cwd": "apps/landing-mytradingcoach"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "astro check",
        "cwd": "apps/landing-mytradingcoach"
      }
    }
  }
}
