{
  "buildCommand": "pnpm nx build landing-mytradingcoach",
  "outputDirectory": "apps/landing-mytradingcoach/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mytradingcoach.app" }],
      "destination": "https://www.mytradingcoach.app/$1",
      "permanent": true
    }
  ]
}
