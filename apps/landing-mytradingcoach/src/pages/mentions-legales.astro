---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Mentions légales — MyTradingCoach"
  description="Mentions légales de MyTradingCoach — éditeur, hébergeur, propriété intellectuelle et conditions d'utilisation du site mytradingcoach.app."
  canonical="https://www.mytradingcoach.app/mentions-legales"
  ogUrl="https://www.mytradingcoach.app/mentions-legales"
>
  <Nav />

  <main style="max-width:48rem; margin:0 auto; padding:4rem 1.5rem;">
    <a href="/" style="display:inline-flex;align-items:center;gap:6px;color:var(--txt3);font-size:13px;text-decoration:none;margin-bottom:2rem;">
      ← Retour à l'accueil
    </a>

    <h1 style="font-size:2rem; font-weight:800; color:var(--text); margin:0 0 0.5rem;">Mentions légales</h1>
    <p style="font-size:0.875rem; color:var(--txt3); margin:0 0 2rem;">
      Conformément aux dispositions de la loi n°2004-575 du 21 juin 2004 pour la Confiance en l'Économie Numérique.
    </p>

    <div style="color:var(--text2); line-height:1.8; font-size:1rem;">

      <h2 style="color:var(--text); font-size:1.25rem; font-weight:700; margin:2rem 0 0.75rem;">1. Éditeur du site</h2>
