---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    slug: 'journal-trading-debutant',
    title: "Journal de Trading pour Débutants : Guide Complet 2026",
    description: "Apprenez à tenir un journal de trading efficace. Nos conseils pour débutants vous aident à analyser vos trades et progresser rapidement.",
    date: '2026-04-01',
    tags: ['journal de trading', 'débutant', 'guide'],
  },
  {
    slug: 'psychologie-trading',
    title: "Psychologie du Trading : Maîtriser ses Émotions pour Trader Mieux",
    description: "Découvrez comment la psychologie du trading impacte vos performances. Biais cognitifs, gestion des émotions et techniques pour trader avec discipline.",
    date: '2026-04-05',
    tags: ['psychologie trading', 'biais cognitifs', 'émotions'],
  },
  {
    slug: 'revenge-trading',
    title: "Revenge Trading : Comment l'Identifier et l'Arrêter Définitivement",
    description: "Le revenge trading détruit les comptes trading. Apprenez à identifier ce comportement toxique et les techniques concrètes pour l'éliminer.",
    date: '2026-04-10',
    tags: ['revenge trading', 'psychologie', 'discipline'],
  },
  {
    slug: 'win-rate-trading',
    title: "Win Rate en Trading : Comment le Calculer et l'Améliorer",
    description: "Le win rate seul ne suffit pas. Découvrez comment calculer votre taux de réussite en trading et pourquoi le ratio R/R est crucial.",
    date: '2026-04-15',
    tags: ['win rate', 'statistiques', 'performance'],
  },
  {
    slug: 'journal-trading-crypto',
    title: "Journal de Trading Crypto : Suivre et Analyser ses Trades BTC/ETH",
    description: "Comment tenir un journal de trading crypto efficace. Suivez vos trades Bitcoin, Ethereum et altcoins pour améliorer vos performances.",
    date: '2026-04-20',
    tags: ['journal trading crypto', 'crypto', 'BTC', 'ETH'],
  },
];
---

<Base
  title="Blog Trading — Conseils et analyses MyTradingCoach"
  description="Conseils de trading, psychologie des marchés et guides pour améliorer votre performance."
  canonical="https://mytradingcoach.app/blog/"
  ogUrl="https://mytradingcoach.app/blog/"
>
  <Nav />

  <main class="blog-index">
    <div class="blog-header">
      <p class="blog-label">Blog</p>
      <h1 class="blog-title">Articles sur le trading</h1>
      <p class="blog-desc">
        Psychologie, méthodes, analyse de performance — pour progresser en tant que trader.
      </p>
    </div>

    <div class="blog-list">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="blog-card">
          <div class="card-tags">
            {post.tags.map(tag => (
              <span class="card-tag">{tag}</span>
            ))}
          </div>
          <h2 class="card-title">{post.title}</h2>
          <p class="card-desc">{post.description}</p>
          <div class="card-footer">
            <span class="card-date">
              {new Date(post.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
            <span class="card-read">Lire →</span>
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</Base>

<style>
  .blog-index {
    max-width: 56rem;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .blog-header {
    margin-bottom: 3rem;
  }

  .blog-label {
    font-size: 0.875rem;
    color: var(--blue2);
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .blog-title {
    font-size: 2.5rem;
    font-weight: 800;
    margin: 0 0 1rem;
    color: var(--txt);
    font-family: var(--disp);
    letter-spacing: -0.5px;
  }

  .blog-desc {
    color: var(--txt2);
    font-size: 1rem;
    max-width: 32rem;
    margin: 0;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Card link reset ── */
  .blog-card {
    display: block;
    background: var(--card);
    border: 1px solid var(--b);
    border-radius: 1rem;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .blog-card:visited {
    color: inherit;
  }

  .blog-card:hover {
    border-color: var(--blue2);
    color: inherit;
  }

  /* ── Tags ── */
  .card-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .card-tag {
    background: var(--card2);
    color: var(--txt3);
    padding: 0.125rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-family: var(--mono);
  }

  /* ── Title ── */
  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--txt);
    font-family: var(--disp);
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  /* ── Description ── */
  .card-desc {
    color: var(--txt2);
    font-size: 0.9375rem;
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  /* ── Footer row ── */
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-date {
    font-size: 0.8125rem;
    color: var(--txt3);
    font-family: var(--mono);
  }

  .card-read {
    color: var(--blue2);
    font-size: 0.875rem;
  }
</style>
