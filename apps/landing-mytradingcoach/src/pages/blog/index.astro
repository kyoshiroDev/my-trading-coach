---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

// Static blog posts listing (no content collections to keep it simple)
const posts = [
  {
    slug: 'journal-trading-debutant',
    title: "Comment tenir un journal de trading qui améliore vraiment tes résultats",
    description: "Découvrez comment un journal de trading bien tenu peut transformer vos performances. Méthode, astuces et analyse IA avec MyTradingCoach.",
    date: '2026-03-01',
    tags: ['journal de trading', 'méthode', 'débutant'],
  },
  {
    slug: 'psychologie-trading',
    title: "Psychologie du trading : les 7 biais qui détruisent ton compte",
    description: "FOMO, overconfidence, anchoring... Ces biais cognitifs coûtent cher. Apprenez à les identifier et les neutraliser grâce aux données.",
    date: '2026-03-05',
    tags: ['psychologie trading', 'biais cognitifs'],
  },
  {
    slug: 'revenge-trading',
    title: "Revenge trading : comment l'identifier et l'arrêter définitivement",
    description: "Le revenge trading est la première cause de comptes liquidés. Voici comment le détecter avec des données et briser ce cycle destructeur.",
    date: '2026-03-10',
    tags: ['revenge trading', 'psychologie', 'discipline'],
  },
  {
    slug: 'win-rate-trading',
    title: "Win rate en trading : ce que votre chiffre cache vraiment",
    description: "Un win rate de 70% peut être moins rentable qu'un win rate de 40%. Comprendre les métriques qui comptent vraiment pour un trader profitable.",
    date: '2026-03-15',
    tags: ['win rate', 'statistiques', 'performance'],
  },
  {
    slug: 'journal-trading-crypto',
    title: "Journal de trading crypto : guide complet + analyse IA en 2026",
    description: "Tout ce qu'il faut savoir pour tenir un journal de trading crypto efficace. Template gratuit inclus.",
    date: '2026-03-20',
    tags: ['journal trading crypto', 'crypto', 'BTC'],
  },
];
---

<Base
  title="Blog Trading — Psychologie, Méthodes, Performance | MyTradingCoach"
  description="Articles sur la psychologie du trading, les méthodes de journaling et l'amélioration des performances. Pour traders crypto, forex et actions."
>
  <Nav />

  <main style="max-width:56rem; margin:0 auto; padding:4rem 1.5rem;">
    <div style="margin-bottom:3rem;">
      <p style="font-size:0.875rem; color:var(--blue2); font-family:var(--mono); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.75rem;">Blog</p>
      <h1 style="font-size:2.5rem; font-weight:800; margin:0 0 1rem; color:var(--text);">Articles sur le trading</h1>
      <p style="color:var(--text2); font-size:1rem; max-width:32rem; margin:0;">
        Psychologie, méthodes, analyse de performance — pour progresser en tant que trader.
      </p>
    </div>

    <div style="display:flex; flex-direction:column; gap:1.5rem;">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} style="display:block; background:var(--card); border:1px solid var(--border); border-radius:1rem; padding:1.5rem; text-decoration:none; transition:border-color 0.2s;">
          <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.75rem;">
            {post.tags.map(tag => (
              <span style="background:rgba(59,130,246,0.1); color:var(--blue2); padding:0.125rem 0.625rem; border-radius:9999px; font-size:0.75rem; font-family:var(--mono);">{tag}</span>
            ))}
          </div>
          <h2 style="font-size:1.25rem; font-weight:700; color:var(--text); margin:0 0 0.5rem; line-height:1.3;">{post.title}</h2>
          <p style="color:var(--text2); font-size:0.9375rem; margin:0 0 1rem; line-height:1.6;">{post.description}</p>
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:0.8125rem; color:var(--text3);">
              {new Date(post.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </span>
            <span style="color:var(--blue2); font-size:0.875rem;">Lire →</span>
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</Base>
