---
const cellCls = (wr: number) => wr >= 66 ? 'hc-grn' : wr >= 50 ? 'hc-ora' : 'hc-red';
const heatDays = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
const heatHours = ['8h','9h','10h','11h','12h','13h','14h','15h','16h','20h','21h','22h'];
const heatData: number[][] = [
  [75,50,74,55,38,48,62,68,55,35,32,28],
  [75,50,80,58,45,50,64,55,58,38,35,30],
  [38,44,76,65,42,46,58,62,52,40,38,32],
  [43,88,68,52,35,38,60,30,42,32,28,25],
  [88,89,47,48,32,44,52,48,38,28,25,22],
  [57,57,78,52,44,48,55,50,48,42,38,35],
  [58,100,55,45,30,28,38,35,32,25,22,20],
];
---

<section class="showcase" id="showcase">
  <div style="max-width:1100px;margin:0 auto">
    <div class="reveal" style="text-align:center;margin-bottom:40px">
      <span class="sec-label">Aperçu de l'app</span>
      <h2>Chaque vue. <em>Chaque détail.</em></h2>
      <p class="sec-sub" style="margin:0 auto;text-align:center">Explore les différentes sections de l'application.</p>
    </div>

    <div class="showcase-tabs reveal">
      <button class="stab active" data-tab="dash">Dashboard</button>
      <button class="stab" data-tab="analytics">Analytics</button>
      <button class="stab" data-tab="ai">IA Insights</button>
      <button class="stab" data-tab="debrief">Weekly Debrief</button>
    </div>

    <!-- DASHBOARD -->
    <div class="showcase-panel active reveal" id="tab-dash">
      <div class="full-screen">
        <div class="full-bar"><div class="sdot" style="background:#ef4444"></div><div class="sdot" style="background:#f59e0b"></div><div class="sdot" style="background:#10b981"></div><span class="screen-url" style="margin-left:10px">Dashboard</span></div>
        <div class="full-body">
          <div class="full-sidebar">
            <div class="flogo"><div class="flogo-ic"><svg width="14" height="14" viewBox="0 0 32 32" fill="none"><polyline points="3,16 6,16 8,10 10,22 12,6 14,20 16,12 18,16 29,16" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div><div class="flogo-txt">MyTrading<span>Coach</span></div></div>
            <div class="fsec">Trading</div>
            <div class="fnav act">⬛ Dashboard</div>
            <div class="fnav">📋 Journal</div>
            <div class="fnav">📊 Analytics</div>
            <div class="fsec">Intelligence</div>
            <div class="fnav">🤖 IA Insights <span class="fbadge">AI</span></div>
            <div class="fnav">📅 Weekly Debrief <span class="fbadge">PRO</span></div>
            <div class="fsec">Compte</div>
            <div class="fnav">🏆 Scoring</div>
            <div class="fuser"><div class="favatar">AX</div><div><div class="funame">Alexandre</div><div class="fuplan">★ PREMIUM</div></div></div>
          </div>
          <div class="full-content">
            <div class="ftopbar">
              <div><h3>Bonjour, Alexandre 👋</h3><div style="font-size:12px;color:var(--txt3);margin-top:3px">Voici un résumé de tes performances</div></div>
              <div style="display:flex;gap:8px"><button class="btn-p" style="font-size:12px;padding:7px 14px">⚡ Ajouter trade</button></div>
            </div>
            <div class="fstats">
              <div class="fstat"><div class="fstat-lbl">P&amp;L Total</div><div class="fstat-val text-g">+$8,420</div><div class="fstat-sub"><span class="fup">▲ +12.3%</span><span>ce mois</span></div></div>
              <div class="fstat"><div class="fstat-lbl">Win Rate</div><div class="fstat-val text-b">67.4%</div><div class="fstat-sub"><span class="fup">▲ +3.2%</span><span>vs préc.</span></div></div>
              <div class="fstat"><div class="fstat-lbl">Drawdown</div><div class="fstat-val text-r">-$1,240</div><div class="fstat-sub"><span class="fdn">▼ -4.8%</span><span>sur cap.</span></div></div>
              <div class="fstat"><div class="fstat-lbl">Trades</div><div class="fstat-val">142</div><div class="fstat-sub"><span class="fup">▲ +18</span><span>sem.</span></div></div>
            </div>
            <div class="fcard">
              <div class="fcard-h"><div class="fcard-t">Equity Curve</div><div style="display:flex;gap:10px"><span style="font-size:10px;color:var(--blue2);font-family:var(--mono);cursor:pointer">3M</span><span style="font-size:10px;color:var(--txt3);font-family:var(--mono)">All</span></div></div>
              <svg width="100%" height="80" viewBox="0 0 600 80" preserveAspectRatio="none">
                <defs><linearGradient id="ecg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#3b82f6" stop-opacity=".25"/><stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/></linearGradient></defs>
                <path d="M0,72 C40,64 70,56 100,50 C130,44 155,38 185,30 C215,22 235,34 260,26 C285,18 310,12 340,9 C370,6 390,14 420,10 C450,6 480,4 520,3 C550,2 575,2 600,2" fill="none" stroke="#3b82f6" stroke-width="2"/>
                <path d="M0,72 C40,64 70,56 100,50 C130,44 155,38 185,30 C215,22 235,34 260,26 C285,18 310,12 340,9 C370,6 390,14 420,10 C450,6 480,4 520,3 C550,2 575,2 600,2 L600,80 L0,80Z" fill="url(#ecg)"/>
                <circle cx="600" cy="2" r="4" fill="#3b82f6"/>
              </svg>
            </div>
            <div class="fgrid2">
              <div class="fcard" style="margin:0">
                <div class="fcard-h"><div class="fcard-t">Win Rate par stratégie</div></div>
                <div style="display:flex;gap:14px;align-items:center">
                  <svg width="72" height="72" viewBox="0 0 100 100"><circle cx="50" cy="50" r="38" fill="none" stroke="#111b2e" stroke-width="10"/><circle cx="50" cy="50" r="38" fill="none" stroke="#10b981" stroke-width="10" stroke-dasharray="160 79" stroke-dashoffset="0" stroke-linecap="round" transform="rotate(-90 50 50)"/><circle cx="50" cy="50" r="38" fill="none" stroke="#3b82f6" stroke-width="10" stroke-dasharray="57 182" stroke-dashoffset="-160" stroke-linecap="round" transform="rotate(-90 50 50)"/><circle cx="50" cy="50" r="38" fill="none" stroke="#ef4444" stroke-width="10" stroke-dasharray="22 217" stroke-dashoffset="-217" stroke-linecap="round" transform="rotate(-90 50 50)"/><text x="50" y="54" text-anchor="middle" font-family="Inter" font-weight="700" font-size="16" fill="#e2eaf5">67%</text></svg>
                  <div style="flex:1;display:flex;flex-direction:column;gap:7px;font-size:11px">
                    <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:var(--green);flex-shrink:0"></div>Breakout<span style="margin-left:auto;font-family:var(--mono);color:var(--txt)">74%</span></div>
                    <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:var(--blue);flex-shrink:0"></div>Pullback<span style="margin-left:auto;font-family:var(--mono);color:var(--txt)">62%</span></div>
                    <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:var(--yel);flex-shrink:0"></div>Range<span style="margin-left:auto;font-family:var(--mono);color:var(--txt)">58%</span></div>
                    <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:var(--red);flex-shrink:0"></div>Reversal<span style="margin-left:auto;font-family:var(--mono);color:var(--txt)">41%</span></div>
                  </div>
                </div>
              </div>
              <div class="fcard" style="margin:0">
                <div class="fcard-h"><div class="fcard-t">États émotionnels</div></div>
                <div style="display:flex;flex-direction:column;gap:10px">
                  <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😤 Revenge</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">23%</span></div><div style="height:5px;background:var(--bg3);border-radius:3px"><div style="width:23%;height:100%;background:var(--red);border-radius:3px"></div></div></div>
                  <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😰 Stress</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">31%</span></div><div style="height:5px;background:var(--bg3);border-radius:3px"><div style="width:31%;height:100%;background:var(--yel);border-radius:3px"></div></div></div>
                  <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😌 Confiant</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">68%</span></div><div style="height:5px;background:var(--bg3);border-radius:3px"><div style="width:68%;height:100%;background:var(--blue);border-radius:3px"></div></div></div>
                  <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>🎯 Focus</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">52%</span></div><div style="height:5px;background:var(--bg3);border-radius:3px"><div style="width:52%;height:100%;background:var(--green);border-radius:3px"></div></div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
