                  <span class="i-tag" style="background:rgba(245,158,11,.1);color:var(--yel)">TIMING</span>
                </div>
                <div class="insight-row">
                  <div class="i-ico" style="background:rgba(16,185,129,.1)">✅</div>
                  <div style="flex:1"><div class="i-t">Setup Breakout : ton point fort</div><div class="i-d">74% win rate sur les breakouts avec confirmation volume.</div></div>
                  <span class="i-tag" style="background:rgba(16,185,129,.1);color:var(--green)">FORCE</span>
                </div>
