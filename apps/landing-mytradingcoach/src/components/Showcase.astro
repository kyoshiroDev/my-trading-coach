---
import MockupShell from './mockup/MockupShell.astro';
import MockupDashboard from './mockup/MockupDashboard.astro';
import MockupAnalytics from './mockup/MockupAnalytics.astro';
import MockupAiInsights from './mockup/MockupAiInsights.astro';
import MockupDebrief from './mockup/MockupDebrief.astro';
---

<section class="showcase" id="showcase">
  <div style="max-width:1100px;margin:0 auto">
    <div class="reveal" style="text-align:center;margin-bottom:40px">
      <span class="sec-label">Aperçu de l'app</span>
      <h2>Chaque vue. <em>Chaque détail.</em></h2>
      <p class="sec-sub" style="margin:0 auto;text-align:center">Explore les différentes sections de l'application.</p>
    </div>

    <div class="showcase-tabs reveal">
      <button class="stab active" data-tab="dash">Dashboard</button>
      <button class="stab" data-tab="analytics">Analytics</button>
      <button class="stab" data-tab="ai">IA Insights</button>
      <button class="stab" data-tab="debrief">Weekly Debrief</button>
    </div>

    <div class="showcase-panel active reveal" id="tab-dash">
      <MockupShell url="app.mytradingcoach.app — Dashboard" active="dashboard">
        <MockupDashboard />
      </MockupShell>
    </div>

    <div class="showcase-panel" id="tab-analytics">
      <MockupShell url="app.mytradingcoach.app — Analytics" active="analytics">
        <MockupAnalytics />
      </MockupShell>
    </div>

    <div class="showcase-panel" id="tab-ai">
      <MockupShell url="app.mytradingcoach.app — IA Insights" active="ai">
        <MockupAiInsights />
      </MockupShell>
    </div>

    <div class="showcase-panel" id="tab-debrief">
      <MockupShell url="app.mytradingcoach.app — Weekly Debrief" active="debrief">
        <MockupDebrief />
      </MockupShell>
    </div>
  </div>
</section>

<style>
  .showcase {
    background: var(--bg2);
    border-top: 1px solid var(--b);
    border-bottom: 1px solid var(--b);
  }

  .showcase-tabs {
    display: flex;
    gap: 4px;
    margin: 0 auto 40px;
    max-width: 1100px;
    background: var(--card);
    padding: 4px;
    border-radius: 10px;
    border: 1px solid var(--b);
    width: fit-content;
  }

  .stab {
    padding: 8px 20px;
    border-radius: 7px;
    font-size: 12px;
    font-family: var(--mono);
    color: var(--txt3);
    cursor: pointer;
    transition: all .2s;
    border: none;
    background: none;
    letter-spacing: .3px;
  }

  .stab.active {
    background: var(--bg3);
    color: var(--blue2);
    border: 1px solid var(--b2);
  }

  .showcase-panel { display: none; max-width: 1100px; margin: 0 auto; }
  .showcase-panel.active { display: block; }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .showcase {
      padding: 48px 0;
      overflow: hidden;
    }

    .showcase > div > .reveal:first-child {
      padding: 0 16px;
    }

    .showcase-tabs {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      width: calc(100% - 32px);
      margin-left: 16px;
      margin-right: 16px;
      box-sizing: border-box;
    }

    .showcase-tabs::-webkit-scrollbar {
      display: none;
    }

    .stab {
      flex-shrink: 0;
      font-size: 11px;
      padding: 6px 12px;
      white-space: nowrap;
    }

    .showcase-panel {
      padding: 0 16px;
    }
  }
</style>

<script>
  document.querySelectorAll('.stab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.stab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.showcase-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      const panel = document.getElementById('tab-' + tab);
      if (panel) panel.classList.add('active');
    });
  });
</script>
