<script>
  // Tab switching
  document.querySelectorAll('.stab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.stab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.showcase-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      const panel = document.getElementById('tab-' + tab);
      if (panel) panel.classList.add('active');
    });
  });

  // Heatmap
  const hvals = [.9,.7,.5,.3,.2,.4,.8,.6,.7,.5,.3,.8,.7,.4,.2,.6,.5,.4,.3,.2,.1,.3,.7,.8,.4,.3,.2,.1,.2,.4,.5,.6,.8,.7,.6,.5,.4,.3,.2,.1];
  const heatContainer = document.getElementById('heatmap-cells');
  if (heatContainer) {
    hvals.forEach(v => {
      const c = v > .7 ? '#10b981' : v > .5 ? '#1e5c3a' : v > .3 ? '#1a3a2a' : '#1a2535';
      const cell = document.createElement('div');
      cell.className = 'hcell';
      cell.style.background = c;
      cell.title = Math.round(v * 100) + '%';
      heatContainer.appendChild(cell);
    });
  }
</script>
