---
const { traders = 14 } = Astro.props;
---

<section class="social-proof" id="temoignages">
  <div class="reveal" style="text-align:center;max-width:560px;margin:0 auto">
    <span class="sec-label">Depuis le lancement</span>
    <h2>Les premiers traders <em>construisent MTC avec nous</em></h2>
    <p class="sec-sub">
      Depuis son lancement, MyTradingCoach réunit déjà <span data-traders-count>{traders}</span> traders. Leurs retours
      façonnent le produit chaque semaine. Rejoins-les.
    </p>
    <a href="https://app.mytradingcoach.app/register" class="join-cta">
      Rejoindre gratuitement →
    </a>
  </div>
</section>

<style>
  .social-proof { padding: 80px 5%; }

  .join-cta {
    display: inline-block;
    margin-top: 24px;
    padding: 13px 26px;
    border-radius: 10px;
    background: linear-gradient(90deg, var(--blue), #6366f1);
    color: #fff;
    font-family: var(--disp);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 0 28px rgba(59, 130, 246, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .join-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 36px rgba(59, 130, 246, 0.5);
  }

  @media (max-width: 768px) {
    .social-proof { padding: 64px 16px; }
  }
</style>
