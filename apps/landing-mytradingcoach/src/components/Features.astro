---
const features = [
  {
    num: '01',
    icon: '📋',
    iconBg: 'rgba(16,185,129,0.08)',
    title: 'Journal intelligent',
    description: "Enregistre chaque trade en 30 secondes. Actif, direction, entry/exit, SL/TP, setup, session, timeframe. Plus ton état émotionnel — l'ingrédient que les autres journaux ignorent.",
    tag: '✓ Gratuit',
    tagClass: 'tag-free',
    featured: false,
  },
  {
    num: '02',
    icon: '💓',
    iconBg: 'rgba(34,211,238,0.08)',
    title: 'Tracking émotionnel',
    description: 'Confiant, stressé, en revenge trading, dans la peur — tu notes ton état à chaque trade. L\'IA corrèle ensuite tes émotions avec tes résultats. Le RR moyen en mode "confiant" vs "stressé" : révélateur.',
    tag: '✓ Gratuit',
    tagClass: 'tag-free',
    featured: true,
  },
  {
    num: '03',
    icon: '📊',
    iconBg: 'rgba(59,130,246,0.08)',
    title: 'Analytics avancés',
    description: "Win rate par stratégie, par heure, par actif, par session. Equity curve. Drawdown. Heatmap de performance hebdomadaire. Tout ce qu'un prop trader professionnel suit sur lui-même.",
    tag: '★ Premium',
    tagClass: 'tag-premium',
    featured: false,
  },
  {
    num: '04',
    icon: '🤖',
    iconBg: 'rgba(139,92,246,0.08)',
    title: 'IA Insights',
    description: 'Claude analyse tes 30 derniers jours de trades et détecte automatiquement tes patterns. "Tu perds après 2 trades perdants consécutifs", "Tes setups Reversal ont un win rate de 41% — arrête-les". Pas des généralités. Tes données.',
    tag: '★ Premium',
    tagClass: 'tag-premium',
    featured: true,
  },
];
---

<section id="features" class="features-section">
  <div class="inner">
    <div class="features-header">
      <span class="section-label">Fonctionnalités</span>
      <h2>Tout ce dont un trader <em>sérieux</em> a besoin</h2>
    </div>
    <div class="features-grid">
      {features.map(f => (
        <div class={`feature-card${f.featured ? ' featured' : ''}`}>
          <span class="feature-number">{f.num}</span>
          <div class="feature-icon-wrap" style={`background:${f.iconBg}`}>{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.description}</p>
          <span class={`feature-tag ${f.tagClass}`}>{f.tag}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 100px 5%;
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .features-header {
    max-width: 620px;
    margin: 0 auto 80px;
    text-align: center;
  }

  .section-label {
    font-size: 11px;
    font-family: var(--mono);
    color: var(--pulse);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: block;
  }

  h2 {
    font-size: clamp(32px, 5vw, 54px);
    font-weight: 700;
    letter-spacing: -2px;
    line-height: 1.05;
    margin-bottom: 20px;
    font-family: var(--display);
    color: var(--text);
  }

  h2 em {
    font-style: italic;
    font-family: var(--serif);
    font-weight: 400;
    color: var(--blue2);
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    max-width: 1100px;
    margin: 0 auto;
  }

  .feature-card {
    background: var(--card);
    padding: 48px 44px;
    position: relative;
    overflow: hidden;
    transition: background 0.2s;
  }

  .feature-card:hover { background: var(--bg3); }

  .feature-card.featured {
    background: linear-gradient(135deg, rgba(59,130,246,0.08), rgba(34,211,238,0.04));
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .feature-card:hover::before { opacity: 0.3; }

  .feature-number {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text3);
    letter-spacing: 1px;
    margin-bottom: 24px;
    display: block;
  }

  .feature-icon-wrap {
    width: 52px; height: 52px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    margin-bottom: 24px;
    border: 1px solid var(--border);
  }

  .feature-card h3 {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
    font-family: var(--display);
    color: var(--text);
  }

  .feature-card p {
    font-size: 15px;
    color: var(--text2);
    line-height: 1.6;
    font-weight: 300;
    margin: 0;
  }

  .feature-tag {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    margin-top: 20px;
    font-size: 11px;
    font-family: var(--mono);
    padding: 4px 10px;
    border-radius: 100px;
  }

  .tag-premium {
    background: linear-gradient(135deg, rgba(59,130,246,0.15), rgba(139,92,246,0.15));
    color: var(--blue2);
    border: 1px solid rgba(59,130,246,0.2);
  }

  .tag-free {
    background: rgba(16,185,129,0.1);
    color: #10b981;
    border: 1px solid rgba(16,185,129,0.2);
  }

  @media (max-width: 768px) {
    .features-grid { grid-template-columns: 1fr; }
    .feature-card { padding: 32px 28px; }
  }
</style>
