---
interface Props {
  url?: string;
  active?: 'dashboard' | 'journal' | 'analytics' | 'ai' | 'debrief' | 'scoring';
  style?: string;
}
const { url = 'app.mytradingcoach.app', active = 'dashboard', style } = Astro.props;
---

<div class="full-screen" style={style}>
  <!-- Barre titre macOS -->
  <div class="full-bar">
    <div class="sdot" style="background:#ef4444"></div>
    <div class="sdot" style="background:#f59e0b"></div>
    <div class="sdot" style="background:#10b981"></div>
    <span class="screen-url">{url}</span>
  </div>

  <div class="full-body">
    <!-- ── Sidebar pixel-perfect ── -->
    <aside class="app-sidebar">

      <!-- Logo -->
      <div class="app-logo">
        <div class="app-logo-ic">
          <svg width="18" height="18" viewBox="0 0 32 32" fill="none">
            <polyline points="3,16 6,16 8,10 10,22 12,6 14,20 16,12 18,16 29,16"
              fill="none" stroke="white" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="app-logo-txt">MyTrading<span>Coach</span></div>
      </div>

      <!-- Nav -->
      <nav class="app-nav">
        <div class="app-nav-section">OVERVIEW</div>

        <a class:list={['app-nav-item', { active: active === 'dashboard' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a class:list={['app-nav-item', { active: active === 'journal' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Journal
        </a>
        <a class:list={['app-nav-item', { active: active === 'analytics' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Analytics
        </a>

        <div class="app-nav-section" style="margin-top:8px">PREMIUM</div>
        <a class:list={['app-nav-item', { active: active === 'ai' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/><path d="M19 3v4"/><path d="M21 5h-4"/></svg>
          IA Insights
          <span class="app-badge">AI</span>
        </a>
        <a class:list={['app-nav-item', { active: active === 'debrief' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Weekly Debrief
          <span class="app-badge">PRO</span>
        </a>

        <div class="app-nav-section" style="margin-top:8px">ACCOUNT</div>
        <a class:list={['app-nav-item', { active: active === 'scoring' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          Scoring
        </a>
        <a class="app-nav-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
          Paramètres
        </a>
      </nav>

      <!-- Footer sidebar -->
      <div class="app-sidebar-footer">
        <!-- Discord button exact -->
        <a class="app-discord-btn" href="#" onclick="return false">
          <svg width="13" height="13" viewBox="0 0 127.14 96.36" fill="currentColor"><path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15zM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69z"/></svg>
          <span>Communauté Discord</span>
          <span class="app-discord-arrow">↗</span>
        </a>
        <!-- User card -->
        <div class="app-user-card">
          <div class="app-avatar">AX</div>
          <div class="app-user-info">
            <div class="app-user-name">Alexandre</div>
            <div class="app-user-plan premium">★ PREMIUM</div>
          </div>
        </div>
      </div>
    </aside>

    <!-- Content -->
    <div class="full-content">
      <slot />
    </div>
  </div>
</div>

<style is:global>
  /* ── Variables de l'app remappées dans le mockup ── */
  .full-screen {
    --app-bg:         #080c14;
    --app-bg2:        #0d1420;
    --app-bg3:        #111b2e;
    --app-card:       #0f1824;
    --app-border:     rgba(99,155,255,0.1);
    --app-border-hov: rgba(99,155,255,0.25);
    --app-blue:       #3b82f6;
    --app-blue-br:    #60a5fa;
    --app-blue-glow:  rgba(59,130,246,0.15);
    --app-green:      #10b981;
    --app-green-dim:  rgba(16,185,129,0.12);
    --app-red:        #ef4444;
    --app-red-dim:    rgba(239,68,68,0.12);
    --app-yellow:     #f59e0b;
    --app-txt:        #e2eaf5;
    --app-txt2:       #8fa3bf;
    --app-txt3:       #7090b0;
    --app-disp:       'Syne', sans-serif;
    --app-mono:       'DM Mono', monospace;
    --app-body:       'DM Sans', sans-serif;
  }

  .full-screen {
    background: var(--app-bg);
    border: 1px solid var(--app-border-hov);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,.7);
    font-family: var(--app-body);
    color: var(--app-txt);
  }

  /* Barre macOS */
  .full-bar {
    background: var(--app-bg3);
    border-bottom: 1px solid var(--app-border);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .sdot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .screen-url { font-size: 11px; color: var(--app-txt3); font-family: var(--app-mono); margin-left: 8px; }

  /* Layout principal */
  .full-body {
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: 500px;
  }

  /* ── SIDEBAR PIXEL-PERFECT ── */
  .app-sidebar {
    width: 240px;
    background: var(--app-bg2);
    border-right: 1px solid var(--app-border);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .app-sidebar::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 1px; height: 100%;
    background: linear-gradient(180deg, transparent, var(--app-blue) 40%, var(--app-blue) 60%, transparent);
    opacity: 0.12;
    pointer-events: none;
  }

  /* Logo */
  .app-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 20px 16px 16px;
    border-bottom: 1px solid var(--app-border);
    flex-shrink: 0;
  }
  .app-logo-ic {
    width: 28px; height: 28px;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .app-logo-txt {
    font-family: var(--app-disp);
    font-size: 14px; font-weight: 700; letter-spacing: -.3px;
    color: var(--app-txt);
  }
  .app-logo-txt span { color: var(--app-blue-br); }

  /* Nav */
  .app-nav {
    flex: 1;
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow: hidden;
  }

  .app-nav-section {
    font-family: var(--app-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.1px;
    color: #4a6080;
    text-transform: uppercase;
    padding: 12px 8px 6px;
    margin-top: 4px;
  }

  .app-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13.5px;
    font-weight: 400;
    color: #4a6080;
    transition: background 0.15s, color 0.15s;
    position: relative;
    text-decoration: none;
  }

  .app-nav-item:hover {
    background: var(--app-blue-glow);
    color: var(--app-txt2);
  }

  .app-nav-item.active {
    background: rgba(59,130,246,0.12);
    color: var(--app-blue-br);
    font-weight: 500;
  }

  .app-nav-item.active::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    transform: translateY(-50%);
    width: 3px; height: 20px;
    background: var(--app-blue);
    border-radius: 0 3px 3px 0;
  }

  .app-badge {
    margin-left: auto;
    background: linear-gradient(135deg, var(--app-blue), #8b5cf6);
    color: white;
    font-size: 9px;
    font-family: var(--app-mono);
    font-weight: 500;
    padding: 2px 6px;
    border-radius: 10px;
    letter-spacing: 0.5px;
  }

  /* Footer sidebar */
  .app-sidebar-footer {
    padding: 16px 12px;
    border-top: 1px solid var(--app-border);
    flex-shrink: 0;
  }

  .app-discord-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    margin-bottom: 8px;
    border-radius: 8px;
    border: 1px solid rgba(88,101,242,0.25);
    background: rgba(88,101,242,0.06);
    color: #7289da;
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    transition: background 0.15s;
    cursor: pointer;
  }
  .app-discord-btn span:nth-child(2) { flex: 1; }
  .app-discord-arrow { font-size: 11px; opacity: 0.5; }

  .app-user-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
  }

  .app-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700;
    font-family: var(--app-disp);
    color: white;
    flex-shrink: 0;
  }

  .app-user-info { flex: 1; min-width: 0; }

  .app-user-name {
    font-size: 13px; font-weight: 500;
    color: var(--app-txt);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .app-user-plan {
    font-size: 10px;
    font-family: var(--app-mono);
    letter-spacing: 0.5px;
  }
  .app-user-plan.premium { color: #60a5fa; }
  .app-user-plan.free    { color: #4a6080; }

  /* Content */
  .full-content {
    overflow: hidden;
    background: var(--app-bg);
    display: flex;
    flex-direction: column;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .app-sidebar { display: none; }
    .full-body { display: block; min-height: unset; }
    .full-content { min-height: unset; }
    .full-screen { display: none; }
  }
</style>
