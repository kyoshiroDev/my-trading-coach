---
interface Props {
  url?: string;
  active?: 'dashboard' | 'journal' | 'analytics' | 'ai' | 'debrief' | 'scoring';
  style?: string;
}
const { url = 'app.mytradingcoach.app', active = 'dashboard', style } = Astro.props;
---

<div class="full-screen" style={style}>
  <!-- Barre titre fenêtre -->
  <div class="full-bar">
    <div class="sdot" style="background:#ef4444"></div>
    <div class="sdot" style="background:#f59e0b"></div>
    <div class="sdot" style="background:#10b981"></div>
    <span class="screen-url">{url}</span>
  </div>

  <div class="full-body">
    <!-- ── Sidebar fidèle à l'app réelle ── -->
    <aside class="full-sidebar">
      <div class="flogo">
        <div class="flogo-ic">
          <svg width="16" height="16" viewBox="0 0 32 32" fill="none">
            <polyline points="3,16 6,16 8,10 10,22 12,6 14,20 16,12 18,16 29,16"
              fill="none" stroke="white" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="flogo-txt">MyTrading<span>Coach</span></div>
      </div>

      <nav class="fnav-wrap">
        <div class="fsec">OVERVIEW</div>
        <a class:list={['fnav-item', { act: active === 'dashboard' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a class:list={['fnav-item', { act: active === 'journal' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Journal
        </a>
        <a class:list={['fnav-item', { act: active === 'analytics' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          Analytics
        </a>

        <div class="fsec" style="margin-top:8px">PREMIUM</div>
        <a class:list={['fnav-item', { act: active === 'ai' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/><path d="M19 3v4"/><path d="M21 5h-4"/></svg>
          IA Insights
          <span class="fbadge ai">AI</span>
        </a>
        <a class:list={['fnav-item', { act: active === 'debrief' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Weekly Debrief
          <span class="fbadge pro">PRO</span>
        </a>

        <div class="fsec" style="margin-top:8px">ACCOUNT</div>
        <a class:list={['fnav-item', { act: active === 'scoring' }]}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
          Scoring
        </a>
        <a class="fnav-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
          Paramètres
        </a>
      </nav>

      <a class="fdiscord-btn" href="#" onclick="return false">
        <svg width="12" height="12" viewBox="0 0 127.14 96.36" fill="currentColor" style="flex-shrink:0;opacity:.7"><path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15zM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69z"/></svg>
        <span>Communauté Discord</span>
        <span style="margin-left:auto;opacity:.4;font-size:9px">↗</span>
      </a>

      <div class="fuser">
        <div class="favatar">AX</div>
        <div class="fuser-info">
          <div class="funame">Alexandre</div>
          <div class="fuplan">★ PREMIUM</div>
        </div>
        <svg class="flogout" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </div>
    </aside>

    <div class="full-content">
      <slot />
    </div>
  </div>
</div>

<style is:global>
  .full-screen {
    background: var(--card);
    border: 1px solid var(--b2);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,.6);
  }

  .full-bar {
    background: var(--bg3);
    border-bottom: 1px solid var(--b);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .sdot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .screen-url { font-size: 11px; color: var(--txt3); font-family: var(--mono); margin-left: 8px; }

  .full-body {
    display: grid;
    grid-template-columns: 240px 1fr;
    min-height: 500px;
  }

  .full-sidebar {
    background: var(--bg3);
    border-right: 1px solid var(--b);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .full-sidebar::after {
    content: '';
    position: absolute;
    top: 0; right: 0; width: 1px; height: 100%;
    background: linear-gradient(180deg, transparent, rgba(59,130,246,0.3) 40%, rgba(59,130,246,0.3) 60%, transparent);
    opacity: 0.4;
  }

  .flogo {
    display: flex; align-items: center; gap: 8px;
    padding: 18px 16px 16px;
    border-bottom: 1px solid var(--b);
    flex-shrink: 0;
  }
  .flogo-ic {
    width: 28px; height: 28px;
    background: linear-gradient(135deg,#3b82f6,#8b5cf6);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .flogo-txt { font-family: var(--disp); font-size: 14px; font-weight: 700; letter-spacing: -.3px; }
  .flogo-txt span { color: #60a5fa; }

  .fnav-wrap {
    flex: 1; padding: 14px 10px;
    display: flex; flex-direction: column; gap: 1px;
    overflow: hidden;
  }

  .fsec {
    font-size: 9px; font-family: var(--mono);
    color: #4a6080;
    letter-spacing: 1.1px; text-transform: uppercase;
    padding: 10px 8px 5px;
  }

  .fnav-item {
    display: flex; align-items: center; gap: 9px;
    padding: 8px 10px; border-radius: 7px;
    font-size: 13px; color: #4a6080;
    cursor: pointer; transition: background .15s, color .15s;
    text-decoration: none; position: relative;
  }
  .fnav-item svg { flex-shrink: 0; }
  .fnav-item:hover { background: rgba(59,130,246,.08); color: #8ba3c7; }
  .fnav-item.act { background: rgba(59,130,246,.12); color: #60a5fa; font-weight: 500; }
  .fnav-item.act::before {
    content: '';
    position: absolute; left: 0; top: 50%;
    transform: translateY(-50%);
    width: 3px; height: 18px;
    background: #3b82f6;
    border-radius: 0 3px 3px 0;
  }

  .fbadge {
    margin-left: auto; font-size: 8px; font-family: var(--mono);
    padding: 2px 6px; border-radius: 8px; font-weight: 700;
  }
  .fbadge.ai  { background: linear-gradient(135deg,#3b82f6,#8b5cf6); color: #fff; }
  .fbadge.pro { background: linear-gradient(135deg,#f59e0b,#ef4444); color: #fff; }

  .fuser {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 14px;
    border-top: 1px solid var(--b);
    flex-shrink: 0;
  }
  .favatar {
    width: 30px; height: 30px; border-radius: 50%;
    background: linear-gradient(135deg,#3b82f6,#8b5cf6);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff;
    flex-shrink: 0; font-family: var(--mono);
  }
  .fuser-info { flex: 1; min-width: 0; }
  .funame { font-size: 12px; font-weight: 500; color: var(--txt); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .fuplan { font-size: 9px; font-family: var(--mono); color: #f59e0b; letter-spacing: .4px; }
  .flogout { color: #4a6080; cursor: pointer; flex-shrink: 0; }

  .fdiscord-btn {
    display: flex; align-items: center; gap: 7px;
    padding: 8px 12px; margin: 0 8px 4px;
    border-radius: 8px; font-size: 11px;
    color: #7b8db0; text-decoration: none;
    border: 1px solid rgba(88,101,242,.15);
    background: rgba(88,101,242,.05);
    transition: background .15s, color .15s;
    cursor: pointer;
  }
  .fdiscord-btn:hover { background: rgba(88,101,242,.1); color: #a0b0d0; }

  .full-content { overflow: hidden; background: var(--bg2); }

  /* ── Atomes partagés ── */
  .fstats {
    display: grid; grid-template-columns: repeat(4,1fr);
    gap: 12px; padding: 0 24px; margin-bottom: 16px;
  }
  .fstat {
    background: var(--card); border: 1px solid var(--b);
    border-radius: 12px; padding: 18px;
    position: relative; overflow: hidden;
    transition: transform .2s, border-color .2s;
  }
  .fstat:hover { transform: translateY(-2px); border-color: var(--b2); }
  .fstat::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, #3b82f6, transparent);
    opacity: 0; transition: opacity .2s;
  }
  .fstat:hover::before { opacity: .4; }
  .fstat-lbl { font-size: 9px; font-family: var(--mono); color: var(--txt3); letter-spacing: .7px; text-transform: uppercase; margin-bottom: 10px; }
  .fstat-val { font-family: var(--disp); font-size: 24px; font-weight: 700; letter-spacing: -.3px; }
  .fstat-sub { font-size: 10px; color: var(--txt3); margin-top: 6px; display: flex; gap: 5px; align-items: center; }
  .fup { color: #10b981; background: rgba(16,185,129,.1); font-family: var(--mono); font-size: 9px; padding: 2px 5px; border-radius: 3px; }
  .fdn { color: #ef4444; background: rgba(239,68,68,.1); font-family: var(--mono); font-size: 9px; padding: 2px 5px; border-radius: 3px; }
  .text-g { color: #10b981; }
  .text-b { color: #60a5fa; }
  .text-r { color: #ef4444; }

  .fcard { background: var(--card); border: 1px solid var(--b); border-radius: 12px; padding: 16px; margin-bottom: 12px; }
  .fcard-h { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .fcard-t { font-family: var(--disp); font-size: 13px; font-weight: 600; letter-spacing: -.1px; }
  .fgrid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }

  .btn-p {
    background: var(--blue); color: #fff; padding: 10px 20px;
    border-radius: 9px; font-size: 13px; font-weight: 600;
    display: inline-flex; align-items: center; gap: 6px;
    border: none; cursor: pointer; font-family: var(--disp);
    box-shadow: 0 0 20px rgba(59,130,246,.3);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .full-sidebar { display: none; }
    .full-body { display: block; min-height: unset; }
    .full-content { padding: 14px; }
    .fstats { grid-template-columns: repeat(2,1fr); padding: 0; }
    .fstat-val { font-size: 18px; }
    .fgrid2 { grid-template-columns: 1fr; }
    .ftopbar { padding: 12px 0 0; }
    .full-screen { display: none; }
  }
</style>
