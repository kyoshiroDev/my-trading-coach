---
const cellCls = (wr: number) => wr >= 66 ? 'hc-grn' : wr >= 50 ? 'hc-ora' : 'hc-red';
const heatDays = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];
const heatHours = ['8h','9h','10h','11h','12h','13h','14h','15h','16h','20h','21h','22h'];
const heatData: number[][] = [
  [75,50,74,55,38,48,62,68,55,35,32,28],
  [75,50,80,58,45,50,64,55,58,38,35,30],
  [38,44,76,65,42,46,58,62,52,40,38,32],
  [43,88,68,52,35,38,60,30,42,32,28,25],
  [88,89,47,48,32,44,52,48,38,28,25,22],
  [57,57,78,52,44,48,55,50,48,42,38,35],
  [58,100,55,45,30,28,38,35,32,25,22,20],
];
---

<div class="ftopbar"><h3>Analytics</h3></div>

<div class="fstats" style="margin-bottom:12px">
  <div class="fstat"><div class="fstat-lbl">WIN RATE GLOBAL</div><div class="fstat-val text-g">67.4%</div><div class="fstat-sub">142 trades</div></div>
  <div class="fstat"><div class="fstat-lbl">P&L TOTAL</div><div class="fstat-val text-g" style="font-size:18px">+$9 829</div><div class="fstat-sub">P&L cumulé</div></div>
  <div class="fstat"><div class="fstat-lbl">TOP SESSION</div><div class="fstat-val text-b" style="font-size:15px">London</div><div class="fstat-sub">74% win rate</div></div>
  <div class="fstat"><div class="fstat-lbl">HEURE TOP</div><div class="fstat-val text-b" style="font-size:18px">09:30</div><div class="fstat-sub">ouverture NY</div></div>
</div>

<div class="an-sep">
  <div class="an-sep-line"></div>
  <span class="an-sep-lbl">ANALYTICS AVANCÉS — PREMIUM</span>
  <div class="an-sep-line"></div>
</div>

<div class="fcard an-heatmap-card">
  <div class="fcard-h"><div class="fcard-t">Heatmap horaire — Win Rate par heure</div></div>
  <div style="overflow-x:auto">
    <table class="hmtable">
      <thead>
        <tr>
          <th class="hm-corner"></th>
          {heatHours.map(h => <th class="hm-hour">{h}</th>)}
        </tr>
      </thead>
      <tbody>
        {heatDays.map((day, di) => (
          <tr>
            <td class="hm-day">{day}</td>
            {heatData[di].map(wr => (
              <td class={`hm-cell ${cellCls(wr)}`}>{wr}%</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<div class="fgrid2">
  <div class="fcard" style="margin:0">
    <div class="fcard-h"><div class="fcard-t">Top actifs</div></div>
    <table class="ftable">
      <thead><tr><th>#</th><th>ASSET</th><th>W%</th><th>P&L</th></tr></thead>
      <tbody>
        <tr><td style="color:var(--txt3);font-family:var(--mono)">#1</td><td style="font-family:var(--mono);color:var(--blue2)">NQ</td><td style="color:var(--green);font-family:var(--mono)">69%</td><td style="font-family:var(--mono);color:var(--green)">+$2 598</td></tr>
        <tr><td style="color:var(--txt3);font-family:var(--mono)">#2</td><td style="font-family:var(--mono);color:var(--blue2)">ETH/USDT</td><td style="color:var(--green);font-family:var(--mono)">73%</td><td style="font-family:var(--mono);color:var(--green)">+$2 203</td></tr>
        <tr><td style="color:var(--txt3);font-family:var(--mono)">#3</td><td style="font-family:var(--mono);color:var(--blue2)">BTC/USDT</td><td style="color:var(--green);font-family:var(--mono)">100%</td><td style="font-family:var(--mono);color:var(--green)">+$2 000</td></tr>
        <tr><td style="color:var(--txt3);font-family:var(--mono)">#4</td><td style="font-family:var(--mono);color:var(--blue2)">ES</td><td style="color:var(--green);font-family:var(--mono)">69%</td><td style="font-family:var(--mono);color:var(--green)">+$1 934</td></tr>
        <tr><td style="color:var(--txt3);font-family:var(--mono)">#5</td><td style="font-family:var(--mono);color:var(--blue2)">SOL/USDT</td><td style="color:var(--yel);font-family:var(--mono)">53%</td><td style="font-family:var(--mono);color:var(--green)">+$1 696</td></tr>
      </tbody>
    </table>
  </div>
  <div class="fcard" style="margin:0">
    <div class="fcard-h"><div class="fcard-t">Performance par setup</div></div>
    <table class="ftable">
      <thead><tr><th>SETUP</th><th>W%</th><th>P&L</th></tr></thead>
      <tbody>
        <tr><td style="font-weight:600">BREAKOUT</td><td style="color:var(--yel);font-family:var(--mono)">48%</td><td style="font-family:var(--mono);color:var(--green)">+$544</td></tr>
        <tr><td style="font-weight:600">PULLBACK</td><td style="color:var(--green);font-family:var(--mono)">80%</td><td style="font-family:var(--mono);color:var(--green)">+$3 389</td></tr>
        <tr><td style="font-weight:600">REVERSAL</td><td style="color:var(--green);font-family:var(--mono)">65%</td><td style="font-family:var(--mono);color:var(--green)">+$2 595</td></tr>
        <tr><td style="font-weight:600">SCALPING</td><td style="color:var(--green);font-family:var(--mono)">70%</td><td style="font-family:var(--mono);color:var(--green)">+$3 937</td></tr>
        <tr><td style="font-weight:600">RANGE</td><td style="color:var(--yel);font-family:var(--mono)">56%</td><td style="font-family:var(--mono);color:var(--green)">+$1 741</td></tr>
        <tr><td style="font-weight:600">NEWS</td><td style="color:var(--red);font-family:var(--mono)">20%</td><td style="font-family:var(--mono);color:var(--red)">-$2 379</td></tr>
      </tbody>
    </table>
  </div>
</div>

<style is:global>
  .an-sep { display:flex; align-items:center; gap:8px; margin-bottom:10px; }
  .an-sep-line { flex:1; height:1px; background:rgba(99,155,255,.1); }
  .an-sep-lbl { font-size:7px; font-family:var(--mono); color:var(--txt3); letter-spacing:.8px; white-space:nowrap; }
  .an-heatmap-card { margin-bottom:10px; }
  .hmtable { border-collapse:separate; border-spacing:2px; width:100%; }
  .hm-corner { width:24px; }
  .hm-hour { font-size:8px; color:var(--txt3); font-family:var(--mono); text-align:center; padding:0 1px 4px; font-weight:400; }
  .hm-day { font-size:8px; color:var(--txt3); font-family:var(--mono); padding:0 4px 0 0; white-space:nowrap; }
  .hm-cell { border-radius:3px; padding:3px 1px; text-align:center; font-size:8px; font-family:var(--mono); font-weight:600; }
  .hc-grn { background:#1e3a2f; color:#10b981; }
  .hc-ora { background:#3a2a0a; color:#f59e0b; }
  .hc-red { background:#3a0f0f; color:#ef4444; }
  .ftable { width:100%; font-size:11px; border-collapse:collapse; }
  .ftable th { font-family:var(--mono); font-size:9px; color:var(--txt3); text-transform:uppercase; letter-spacing:.6px; padding-bottom:7px; text-align:left; border-bottom:1px solid var(--b); }
  .ftable td { padding:7px 0; color:var(--txt2); border-bottom:1px solid rgba(99,155,255,.04); text-align:left; }
  .ftable tr:last-child td { border:none; }
</style>
