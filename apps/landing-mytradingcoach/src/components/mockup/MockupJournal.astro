---
---

<!-- Topbar exact -->
<div class="app-topbar">
  <h1 class="app-page-title">Journal</h1>
  <button class="app-btn-primary">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nouveau trade
  </button>
</div>

<div class="jnl-content">

  <!-- Barre filtres -->
  <div class="jnl-filters-bar">
    <div class="jnl-filter-chips">
      <button class="jnl-chip active">Tous</button>
      <button class="jnl-chip">LONG</button>
      <button class="jnl-chip">SHORT</button>
      <button class="jnl-chip">BREAKOUT</button>
      <button class="jnl-chip">PULLBACK</button>
      <button class="jnl-chip">SCALPING</button>
    </div>
    <div class="jnl-filter-right">
      <div class="jnl-date-presets">
        <button class="jnl-preset">Auj.</button>
        <button class="jnl-preset">Sem.</button>
        <button class="jnl-preset active">Mois</button>
        <button class="jnl-preset">Tout</button>
        <button class="jnl-preset" style="display:flex;align-items:center;gap:4px">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Custom
        </button>
      </div>
      <button class="jnl-chip" style="gap:5px;border-color:rgba(59,130,246,.3);color:#60a5fa">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
        CSV
      </button>
    </div>
  </div>

  <!-- Résumé période exact -->
  <div class="jnl-period-summary">
    <div class="jnl-period-stat">
      <span class="jnl-period-label">TRADES</span>
      <span class="jnl-period-value">18</span>
    </div>
    <div class="jnl-period-stat">
      <span class="jnl-period-label">WIN RATE</span>
      <span class="jnl-period-value">67%</span>
    </div>
    <div class="jnl-period-stat">
      <span class="jnl-period-label">P&L NET</span>
      <span class="jnl-period-value" style="color:var(--app-green)">+$1 420</span>
      <span class="jnl-period-sub">brut $1 480 · frais $60</span>
    </div>
    <div class="jnl-period-stat">
      <span class="jnl-period-label">MEILLEUR</span>
      <span class="jnl-period-value" style="color:var(--app-green)">+$620</span>
    </div>
    <div class="jnl-period-stat">
      <span class="jnl-period-label">PIRE</span>
      <span class="jnl-period-value" style="color:var(--app-red)">-$280</span>
    </div>
  </div>

  <!-- Journal wrap avec header colonnes + groupes par jour -->
  <div class="jnl-wrap">

    <!-- Header colonnes unique -->
    <div class="jnl-table-header">
      <span>Asset</span>
      <span>Sens</span>
      <span>Entry</span>
      <span>Exit</span>
      <span>P&L</span>
      <span>Qté</span>
      <span>R/R</span>
      <span>Émotion</span>
      <span>Setup</span>
      <span></span>
    </div>

    <!-- Jour 1 — déplié, P&L positif -->
    <div class="jnl-day-group">
      <div class="jnl-day-header">
        <div class="jnl-accent" style="background:var(--app-green)"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color:var(--app-txt3);flex-shrink:0"><polyline points="6 9 12 15 18 9"/></svg>
        <div class="jnl-day-label">Mercredi 14 mai 2025</div>
        <div class="jnl-day-stats">
          <span class="jnl-day-count">3 trades</span>
          <span class="jnl-dot">·</span>
          <span class="jnl-day-wr">2/3</span>
          <span class="jnl-dot">·</span>
          <span class="jnl-day-pnl positive">+$740</span>
        </div>
        <button class="jnl-day-delete-btn" title="Supprimer">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </button>
      </div>

      <div class="jnl-trades">
        <!-- Trade 1 -->
        <div class="jnl-trade-row">
          <span class="jnl-td jnl-asset">BTC/USDT</span>
          <span class="jnl-td"><span class="jnl-side long">LONG</span></span>
          <span class="jnl-td jnl-mono">42 150</span>
          <span class="jnl-td jnl-mono">42 580</span>
          <span class="jnl-td jnl-mono" style="color:var(--app-green)">+$400</span>
          <span class="jnl-td jnl-mono">0.1</span>
          <span class="jnl-td jnl-mono">2.1</span>
          <span class="jnl-td"><span class="jnl-emo-cell">😌 <span class="jnl-emo-txt">CONFIDENT</span></span></span>
          <span class="jnl-td"><span class="jnl-setup-badge">BREAKOUT</span></span>
          <span class="jnl-td jnl-actions">
            <button class="jnl-btn-edit"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
            <button class="jnl-btn-del"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
          </span>
        </div>
        <!-- Trade 2 -->
        <div class="jnl-trade-row">
          <span class="jnl-td jnl-asset">EUR/USD</span>
          <span class="jnl-td"><span class="jnl-side short">SHORT</span></span>
          <span class="jnl-td jnl-mono">1.0842</span>
          <span class="jnl-td jnl-mono">1.0814</span>
          <span class="jnl-td jnl-mono" style="color:var(--app-green)">+$280</span>
          <span class="jnl-td jnl-mono">1</span>
          <span class="jnl-td jnl-mono">1.8</span>
          <span class="jnl-td"><span class="jnl-emo-cell">🎯 <span class="jnl-emo-txt">FOCUSED</span></span></span>
          <span class="jnl-td"><span class="jnl-setup-badge">PULLBACK</span></span>
          <span class="jnl-td jnl-actions">
            <button class="jnl-btn-edit"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
            <button class="jnl-btn-del"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
          </span>
        </div>
        <!-- Trade 3 -->
        <div class="jnl-trade-row">
          <span class="jnl-td jnl-asset">NQ</span>
          <span class="jnl-td"><span class="jnl-side long">LONG</span></span>
          <span class="jnl-td jnl-mono">17 840</span>
          <span class="jnl-td jnl-mono">17 790</span>
          <span class="jnl-td jnl-mono" style="color:var(--app-red)">-$280</span>
          <span class="jnl-td jnl-mono">1</span>
          <span class="jnl-td jnl-mono">—</span>
          <span class="jnl-td"><span class="jnl-emo-cell">😤 <span class="jnl-emo-txt">REVENGE</span></span></span>
          <span class="jnl-td"><span class="jnl-setup-badge">SCALPING</span></span>
          <span class="jnl-td jnl-actions">
            <button class="jnl-btn-edit"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
            <button class="jnl-btn-del"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
          </span>
        </div>
      </div>
    </div>

    <!-- Jour 2 — replié, P&L négatif + frais -->
    <div class="jnl-day-group">
      <div class="jnl-day-header">
        <div class="jnl-accent" style="background:var(--app-red)"></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color:var(--app-txt3);flex-shrink:0"><polyline points="9 18 15 12 9 6"/></svg>
        <div class="jnl-day-label">Mardi 13 mai 2025</div>
        <div class="jnl-day-stats">
          <span class="jnl-day-count">2 trades</span>
          <span class="jnl-dot">·</span>
          <span class="jnl-day-wr">1/2</span>
          <span class="jnl-dot">·</span>
          <span class="jnl-day-pnl negative">-$120</span>
          <span class="jnl-day-fees">-$18 frais</span>
        </div>
        <button class="jnl-day-delete-btn">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        </button>
      </div>
    </div>

  </div>
</div>

<style is:global>
  .app-topbar {
    position: sticky; top: 0;
    background: rgba(8,12,20,0.85);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--app-border);
    padding: 0 28px; height: 60px;
    display: flex; align-items: center; gap: 16px;
    z-index: 5; flex-shrink: 0;
  }
  .app-page-title {
    font-family: 'Syne', sans-serif;
    font-size: 17px; font-weight: 700; letter-spacing: -0.3px;
    flex: 1; color: var(--app-txt);
  }
  .app-btn-primary {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px; border-radius: 8px; font-size: 13px; font-weight: 500;
    background: var(--app-blue); color: white; border: none;
    box-shadow: 0 0 20px rgba(59,130,246,.3); cursor: pointer;
    font-family: 'DM Sans', sans-serif;
  }

  /* Content */
  .jnl-content {
    padding: 24px 28px;
    flex: 1;
    display: flex; flex-direction: column; gap: 10px;
  }

  /* Filtres */
  .jnl-filters-bar {
    display: flex; align-items: center;
    justify-content: space-between; gap: 12px; flex-wrap: wrap;
  }
  .jnl-filter-chips { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .jnl-filter-right { display: flex; align-items: center; gap: 8px; }
  .jnl-chip {
    padding: 5px 12px; border-radius: 100px;
    font-size: 11px; font-family: 'DM Mono', monospace;
    cursor: pointer; border: 1px solid var(--app-border);
    color: var(--app-txt2); background: transparent;
    transition: background .15s, border-color .15s, color .15s; white-space: nowrap;
    display: inline-flex; align-items: center;
  }
  .jnl-chip:hover, .jnl-chip.active {
    background: var(--app-blue-glow); border-color: var(--app-blue); color: var(--app-blue-br);
  }

  /* Date presets */
  .jnl-date-presets {
    display: flex; align-items: center;
    background: var(--app-card); border: 1px solid var(--app-border);
    border-radius: 8px; padding: 2px; gap: 2px;
  }
  .jnl-preset {
    padding: 4px 10px; border-radius: 6px;
    font-size: 11px; font-family: 'DM Mono', monospace;
    cursor: pointer; border: none; background: transparent;
    color: var(--app-txt3); transition: background .12s, color .12s;
    white-space: nowrap; display: flex; align-items: center; gap: 4px;
  }
  .jnl-preset:hover { color: var(--app-txt); background: var(--app-bg3); }
  .jnl-preset.active { background: var(--app-blue); color: white; }

  /* Résumé période */
  .jnl-period-summary {
    display: flex; align-items: stretch;
    background: var(--app-card); border: 1px solid var(--app-border);
    border-radius: 10px; overflow: hidden;
  }
  .jnl-period-stat {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    gap: 3px; padding: 7px 16px;
    border-right: 1px solid var(--app-border);
  }
  .jnl-period-stat:last-child { border-right: none; }
  .jnl-period-label {
    font-size: 9px; font-family: 'DM Mono', monospace;
    color: var(--app-txt3); text-transform: uppercase; letter-spacing: 0.08em;
  }
  .jnl-period-value {
    font-size: 14px; font-weight: 600;
    font-family: 'DM Mono', monospace; color: var(--app-txt);
  }
  .jnl-period-sub {
    font-size: 9px; font-family: 'DM Mono', monospace;
    color: var(--app-txt3); margin-top: 2px;
  }

  /* Journal wrap */
  .jnl-wrap {
    background: var(--app-card);
    border: 1px solid var(--app-border);
    border-radius: 12px; overflow: hidden;
  }

  /* Header colonnes */
  .jnl-table-header {
    display: grid;
    grid-template-columns: 1.2fr 0.7fr 0.9fr 0.9fr 1.3fr 0.5fr 0.6fr 1.3fr 1.1fr 64px;
    padding: 5px 16px 5px 32px;
    border-bottom: 1px solid var(--app-border);
    background: var(--app-bg2); gap: 0;
  }
  .jnl-table-header > span {
    font-size: 9px; font-family: 'DM Mono', monospace;
    font-weight: 600; color: var(--app-txt3);
    text-transform: uppercase; letter-spacing: 0.1em;
  }

  /* Groupes par jour */
  .jnl-day-group { border-bottom: 1px solid var(--app-border); }
  .jnl-day-group:last-child { border-bottom: none; }

  .jnl-day-header {
    display: flex; align-items: center; gap: 10px;
    padding: 7px 16px; cursor: pointer;
    transition: background .12s;
    user-select: none; position: relative;
  }
  .jnl-day-header:hover { background: var(--app-bg2); }
  .jnl-day-header:hover .jnl-day-delete-btn { opacity: 1; }

  .jnl-accent { position: absolute; left: 0; top: 0; bottom: 0; width: 3px; }

  .jnl-day-label {
    font-size: 13px; font-weight: 600;
    color: var(--app-txt); text-transform: capitalize;
    flex: 1; min-width: 0;
  }
  .jnl-day-stats {
    display: flex; align-items: center; gap: 7px;
    font-size: 11px; font-family: 'DM Mono', monospace; flex-shrink: 0;
  }
  .jnl-day-count { color: var(--app-txt3); }
  .jnl-dot { color: var(--app-txt3); opacity: .4; }
  .jnl-day-wr { color: var(--app-txt2); }
  .jnl-day-pnl { font-weight: 700; font-size: 12px; }
  .jnl-day-pnl.positive { color: var(--app-green); }
  .jnl-day-pnl.negative { color: var(--app-red); }
  .jnl-day-fees { font-size: 10px; color: var(--app-red); opacity: .7; }

  .jnl-day-delete-btn {
    width: 24px; height: 24px;
    border-radius: 5px; border: 1px solid transparent;
    background: transparent; color: var(--app-txt3);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity .15s, background .15s, color .15s;
    flex-shrink: 0; margin-left: 4px;
  }
  .jnl-day-delete-btn:hover {
    background: rgba(239,68,68,.1); border-color: rgba(239,68,68,.3); color: var(--app-red);
  }

  /* Trades */
  .jnl-trades { }
  .jnl-trade-row {
    display: grid;
    grid-template-columns: 1.2fr 0.7fr 0.9fr 0.9fr 1.3fr 0.5fr 0.6fr 1.3fr 1.1fr 64px;
    align-items: center;
    padding: 7px 16px; gap: 0;
    border-bottom: 1px solid rgba(99,155,255,.04);
    background: var(--app-bg); font-size: 12px;
    transition: background .1s;
  }
  .jnl-trade-row:hover { background: var(--app-bg2); }
  .jnl-trade-row:last-child { border-bottom: none; }

  .jnl-td { color: var(--app-txt2); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
  .jnl-mono { font-family: 'DM Mono', monospace; }
  .jnl-asset { color: var(--app-txt); font-weight: 600; font-family: 'DM Mono', monospace; }

  .jnl-side {
    font-size: 9px; font-weight: 700;
    font-family: 'DM Mono', monospace;
    padding: 2px 6px; border-radius: 4px; display: inline-block;
  }
  .jnl-side.long  { background: var(--app-green-dim); color: var(--app-green); }
  .jnl-side.short { background: var(--app-red-dim); color: var(--app-red); }

  .jnl-emo-cell { display: flex; align-items: center; gap: 4px; font-size: 12px; }
  .jnl-emo-txt { font-size: 9px; color: var(--app-txt3); font-family: 'DM Mono', monospace; }

  .jnl-setup-badge {
    font-size: 9px; font-family: 'DM Mono', monospace; font-weight: 600;
    padding: 2px 7px; border-radius: 4px;
    background: rgba(59,130,246,.08);
    color: var(--app-blue-br);
    border: 1px solid rgba(59,130,246,.15);
    display: inline-block;
  }

  .jnl-actions { display: flex; align-items: center; gap: 2px; }
  .jnl-btn-edit, .jnl-btn-del {
    width: 22px; height: 22px; border-radius: 4px; border: none;
    background: transparent; cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--app-txt3); transition: background .1s, color .1s;
  }
  .jnl-btn-edit:hover { background: rgba(59,130,246,.08); color: var(--app-blue-br); }
  .jnl-btn-del:hover  { background: rgba(239,68,68,.08); color: var(--app-red); }
</style>
