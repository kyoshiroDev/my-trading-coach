---
---

<!-- Topbar -->
<div class="fjnl-topbar">
  <h1 class="fjnl-page-title">Journal</h1>
  <button class="btn-p" style="font-size:11px;padding:7px 14px;gap:5px">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nouveau trade
  </button>
</div>

<div style="padding:0 16px 16px">

  <!-- Barre de filtres -->
  <div class="fjnl-filters">
    <div class="fjnl-chips">
      <button class="fjnl-chip active">Tous</button>
      <button class="fjnl-chip">LONG</button>
      <button class="fjnl-chip">SHORT</button>
      <button class="fjnl-chip">BREAKOUT</button>
      <button class="fjnl-chip">PULLBACK</button>
      <button class="fjnl-chip">SCALPING</button>
    </div>
    <div class="fjnl-dates">
      <button class="fjnl-preset">Auj.</button>
      <button class="fjnl-preset">Sem.</button>
      <button class="fjnl-preset active">Mois</button>
      <button class="fjnl-preset">Tout</button>
      <button class="fjnl-chip" style="display:inline-flex;align-items:center;gap:4px;font-size:10px">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Custom
      </button>
      <button class="fjnl-chip" style="display:inline-flex;align-items:center;gap:4px;font-size:10px">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
        CSV
      </button>
    </div>
  </div>

  <!-- Résumé période -->
  <div class="fjnl-summary">
    <div class="fjnl-pstat">
      <span class="fjnl-plbl">Trades</span>
      <span class="fjnl-pval">18</span>
    </div>
    <div class="fjnl-pstat">
      <span class="fjnl-plbl">Win rate</span>
      <span class="fjnl-pval">67%</span>
    </div>
    <div class="fjnl-pstat">
      <span class="fjnl-plbl">P&L Net</span>
      <span class="fjnl-pval" style="color:#10b981">+$1 420</span>
    </div>
    <div class="fjnl-pstat">
      <span class="fjnl-plbl">Meilleur</span>
      <span class="fjnl-pval" style="color:#10b981">+$620</span>
    </div>
    <div class="fjnl-pstat">
      <span class="fjnl-plbl">Pire</span>
      <span class="fjnl-pval" style="color:#ef4444">-$280</span>
    </div>
  </div>

  <!-- Header colonnes -->
  <div class="fjnl-thead">
    <span class="fjnl-th th-asset">Asset</span>
    <span class="fjnl-th th-side">Sens</span>
    <span class="fjnl-th th-price">Entry</span>
    <span class="fjnl-th th-price">Exit</span>
    <span class="fjnl-th th-pnl">P&L</span>
    <span class="fjnl-th th-qty">Qté</span>
    <span class="fjnl-th th-rr">R/R</span>
    <span class="fjnl-th th-emotion">Émotion</span>
    <span class="fjnl-th th-setup">Setup</span>
    <span class="fjnl-th th-actions"></span>
  </div>

  <!-- Jour 1 — Mercredi 14 mai 2025 -->
  <div class="fjnl-day">
    <div class="fjnl-day-header">
      <div class="fjnl-accent" style="background:#10b981"></div>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color:var(--txt3);flex-shrink:0"><polyline points="6 9 12 15 18 9"/></svg>
      <div class="fjnl-day-label">Mercredi 14 mai 2025</div>
      <div class="fjnl-day-stats">
        <span class="fjnl-day-count">3 trades</span>
        <span class="fjnl-dot">·</span>
        <span class="fjnl-day-wr">2/3</span>
        <span class="fjnl-dot">·</span>
        <span class="fjnl-day-pnl positive">+$740</span>
      </div>
      <button class="fjnl-trash" title="Supprimer la journée">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      </button>
    </div>
    <div class="fjnl-trades">
      <div class="fjnl-row">
        <span class="fjnl-td td-asset">BTC/USDT</span>
        <span class="fjnl-td td-side"><span class="ftrade-side long">LONG</span></span>
        <span class="fjnl-td td-price mono">42 150</span>
        <span class="fjnl-td td-price mono">42 580</span>
        <span class="fjnl-td td-pnl mono" style="color:#10b981">+$400</span>
        <span class="fjnl-td td-qty mono">0.1</span>
        <span class="fjnl-td td-rr mono">2.1</span>
        <span class="fjnl-td td-emotion"><span class="femotion-cell">😌 <span class="femotion-txt">CONFIDENT</span></span></span>
        <span class="fjnl-td td-setup"><span class="fsetup-badge">BREAKOUT</span></span>
        <span class="fjnl-td td-actions">
          <button class="fjnl-btn-edit"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
          <button class="fjnl-btn-del"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </span>
      </div>
      <div class="fjnl-row">
        <span class="fjnl-td td-asset">EUR/USD</span>
        <span class="fjnl-td td-side"><span class="ftrade-side short">SHORT</span></span>
        <span class="fjnl-td td-price mono">1.0842</span>
        <span class="fjnl-td td-price mono">1.0814</span>
        <span class="fjnl-td td-pnl mono" style="color:#10b981">+$280</span>
        <span class="fjnl-td td-qty mono">1</span>
        <span class="fjnl-td td-rr mono">1.8</span>
        <span class="fjnl-td td-emotion"><span class="femotion-cell">🎯 <span class="femotion-txt">FOCUSED</span></span></span>
        <span class="fjnl-td td-setup"><span class="fsetup-badge">PULLBACK</span></span>
        <span class="fjnl-td td-actions">
          <button class="fjnl-btn-edit"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
          <button class="fjnl-btn-del"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </span>
      </div>
      <div class="fjnl-row">
        <span class="fjnl-td td-asset">NQ</span>
        <span class="fjnl-td td-side"><span class="ftrade-side long">LONG</span></span>
        <span class="fjnl-td td-price mono">17 840</span>
        <span class="fjnl-td td-price mono">17 790</span>
        <span class="fjnl-td td-pnl mono" style="color:#ef4444">-$280</span>
        <span class="fjnl-td td-qty mono">1</span>
        <span class="fjnl-td td-rr mono">—</span>
        <span class="fjnl-td td-emotion"><span class="femotion-cell">😤 <span class="femotion-txt">REVENGE</span></span></span>
        <span class="fjnl-td td-setup"><span class="fsetup-badge">SCALPING</span></span>
        <span class="fjnl-td td-actions">
          <button class="fjnl-btn-edit"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
          <button class="fjnl-btn-del"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </span>
      </div>
    </div>
  </div>

  <!-- Jour 2 — Mardi 13 mai 2025 (replié) -->
  <div class="fjnl-day">
    <div class="fjnl-day-header">
      <div class="fjnl-accent" style="background:#ef4444"></div>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color:var(--txt3);flex-shrink:0"><polyline points="9 18 15 12 9 6"/></svg>
      <div class="fjnl-day-label">Mardi 13 mai 2025</div>
      <div class="fjnl-day-stats">
        <span class="fjnl-day-count">2 trades</span>
        <span class="fjnl-dot">·</span>
        <span class="fjnl-day-wr">1/2</span>
        <span class="fjnl-dot">·</span>
        <span class="fjnl-day-pnl negative">-$120</span>
        <span class="fjnl-day-fees">-$18 frais</span>
      </div>
      <button class="fjnl-trash">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      </button>
    </div>
    <!-- replié — trades masqués -->
  </div>

</div>

<style>
  .fjnl-topbar {
    display: flex; align-items: center;
    justify-content: space-between;
    padding: 14px 16px 12px;
    border-bottom: 1px solid var(--b);
  }
  .fjnl-page-title {
    font-family: var(--disp); font-size: 17px; font-weight: 700;
    letter-spacing: -.3px; color: var(--txt);
  }

  /* Filtres */
  .fjnl-filters {
    display: flex; align-items: center; justify-content: space-between;
    gap: 8px; margin: 12px 0 8px; flex-wrap: wrap;
  }
  .fjnl-chips { display: flex; flex-wrap: wrap; gap: 4px; }
  .fjnl-dates { display: flex; align-items: center; gap: 4px; }
  .fjnl-chip {
    padding: 3px 9px; border-radius: 100px;
    border: 1px solid var(--b); background: transparent;
    font-size: 10px; color: var(--txt3);
    cursor: pointer; white-space: nowrap;
    font-family: var(--mono);
  }
  .fjnl-chip.active { background: rgba(59,130,246,.1); border-color: var(--blue); color: var(--blue); }
  .fjnl-preset {
    padding: 3px 8px; border-radius: 6px;
    border: 1px solid var(--b); background: transparent;
    font-size: 10px; color: var(--txt3);
    cursor: pointer; font-family: var(--mono);
  }
  .fjnl-preset.active { background: rgba(59,130,246,.1); border-color: var(--blue); color: var(--blue); }

  /* Résumé période */
  .fjnl-summary {
    display: flex; gap: 0;
    background: var(--card); border: 1px solid var(--b);
    border-radius: 8px; margin-bottom: 10px; overflow: hidden;
  }
  .fjnl-pstat {
    flex: 1; padding: 8px 10px;
    display: flex; flex-direction: column; gap: 2px;
    border-right: 1px solid var(--b);
  }
  .fjnl-pstat:last-child { border-right: none; }
  .fjnl-plbl { font-size: 9px; font-family: var(--mono); color: var(--txt3); letter-spacing: .4px; }
  .fjnl-pval { font-size: 13px; font-weight: 700; font-family: var(--mono); color: var(--txt); }

  /* Header colonnes */
  .fjnl-thead {
    display: grid;
    grid-template-columns: 80px 52px 72px 72px 70px 40px 40px 100px 80px 52px;
    padding: 5px 8px;
    gap: 0;
  }
  .fjnl-th {
    font-size: 8px; font-family: var(--mono); color: var(--txt3);
    text-transform: uppercase; letter-spacing: .6px;
  }

  /* Groupe jour */
  .fjnl-day { margin-bottom: 6px; }
  .fjnl-day-header {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 10px;
    background: var(--bg3); border: 1px solid var(--b);
    border-radius: 8px; cursor: pointer;
    position: relative; overflow: hidden;
  }
  .fjnl-day-header:hover .fjnl-trash { opacity: 1; }
  .fjnl-accent {
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px;
  }
  .fjnl-day-label {
    font-size: 11px; font-weight: 600; color: var(--txt);
    font-family: var(--mono); flex: 1;
  }
  .fjnl-day-stats {
    display: flex; align-items: center; gap: 6px;
    font-size: 10px; color: var(--txt3); font-family: var(--mono);
  }
  .fjnl-day-count { color: var(--txt3); }
  .fjnl-dot { opacity: .4; }
  .fjnl-day-wr { color: var(--txt2); }
  .fjnl-day-pnl { font-weight: 600; }
  .fjnl-day-pnl.positive { color: #10b981; }
  .fjnl-day-pnl.negative { color: #ef4444; }
  .fjnl-day-fees { font-size: 9px; color: #ef4444; opacity: .7; }
  .fjnl-trash {
    width: 22px; height: 22px; display: flex;
    align-items: center; justify-content: center;
    border-radius: 5px; border: 1px solid transparent;
    background: transparent; color: var(--txt3);
    cursor: pointer; opacity: 0; transition: opacity .15s, background .15s, color .15s;
    flex-shrink: 0;
  }
  .fjnl-trash:hover { background: rgba(239,68,68,.1); border-color: rgba(239,68,68,.3); color: #ef4444; }

  /* Trades */
  .fjnl-trades { border: 1px solid var(--b); border-top: none; border-radius: 0 0 8px 8px; overflow: hidden; }
  .fjnl-row {
    display: grid;
    grid-template-columns: 80px 52px 72px 72px 70px 40px 40px 100px 80px 52px;
    align-items: center;
    padding: 7px 10px; gap: 0;
    border-bottom: 1px solid rgba(99,155,255,.04);
    background: var(--bg2);
    font-size: 11px;
  }
  .fjnl-row:last-child { border-bottom: none; }
  .fjnl-td { color: var(--txt2); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
  .mono { font-family: var(--mono); }
  .td-asset { color: var(--txt); font-weight: 600; font-family: var(--mono); font-size: 11px; }

  .ftrade-side { font-size: 8px; font-weight: 700; font-family: var(--mono); padding: 2px 5px; border-radius: 3px; }
  .ftrade-side.long  { background: rgba(16,185,129,.12); color: #10b981; }
  .ftrade-side.short { background: rgba(239,68,68,.12); color: #ef4444; }

  .femotion-cell { display: flex; align-items: center; gap: 4px; font-size: 11px; }
  .femotion-txt { font-size: 9px; color: var(--txt3); font-family: var(--mono); }

  .fsetup-badge {
    font-size: 9px; font-family: var(--mono); font-weight: 600;
    padding: 2px 7px; border-radius: 4px;
    background: rgba(59,130,246,.08);
    color: var(--blue2); border: 1px solid rgba(59,130,246,.15);
  }

  .fjnl-btn-edit, .fjnl-btn-del {
    width: 22px; height: 22px; border-radius: 4px; border: none;
    background: transparent; cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--txt3); transition: background .1s, color .1s;
  }
  .fjnl-btn-edit:hover { background: rgba(59,130,246,.08); color: var(--blue2); }
  .fjnl-btn-del:hover  { background: rgba(239,68,68,.08); color: #ef4444; }
  .td-actions { display: flex; align-items: center; gap: 2px; }
</style>
