---
---
<!-- Topbar réelle -->
<div class="fdash-topbar">
  <div>
    <div class="fdash-title">Bonjour, Alexandre 👋</div>
    <div class="fdash-sub">Voici un résumé de ton activité de trading</div>
  </div>
  <button class="btn-p" style="font-size:12px;padding:8px 16px">⚡ Ajouter trade</button>
</div>

<div style="padding:0 24px 24px">
  <!-- 4 stat cards -->
  <div class="fstats" style="padding:0;margin-bottom:16px">
    <div class="fstat"><div class="fstat-lbl">P&L Total</div><div class="fstat-val text-g">+$8,420</div><div class="fstat-sub"><span class="fup">▲ +12.3%</span><span>ce mois</span></div></div>
    <div class="fstat"><div class="fstat-lbl">Win Rate</div><div class="fstat-val text-b">67.4%</div><div class="fstat-sub"><span class="fup">▲ +3.2%</span><span>vs préc.</span></div></div>
    <div class="fstat"><div class="fstat-lbl">Drawdown</div><div class="fstat-val text-r">-$1,240</div><div class="fstat-sub"><span class="fdn">▼ -4.8%</span><span>sur cap.</span></div></div>
    <div class="fstat"><div class="fstat-lbl">Trades</div><div class="fstat-val">142</div><div class="fstat-sub"><span class="fup">▲ +18</span><span>sem.</span></div></div>
  </div>

  <!-- Equity Curve -->
  <div class="fcard">
    <div class="fcard-h">
      <div class="fcard-t">Equity Curve</div>
      <div style="display:flex;gap:10px">
        <span style="font-size:10px;color:#60a5fa;font-family:var(--mono);cursor:pointer;font-weight:600">3M</span>
        <span style="font-size:10px;color:var(--txt3);font-family:var(--mono);cursor:pointer">All</span>
      </div>
    </div>
    <svg width="100%" height="72" viewBox="0 0 600 72" preserveAspectRatio="none">
      <defs>
        <linearGradient id="ecg2" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#3b82f6" stop-opacity=".2"/>
          <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <path d="M0,70 C40,65 80,58 130,48 C180,38 210,44 250,32 C290,20 320,14 360,9 C400,4 430,10 470,7 C510,4 550,2 600,1" fill="none" stroke="#3b82f6" stroke-width="1.8"/>
      <path d="M0,70 C40,65 80,58 130,48 C180,38 210,44 250,32 C290,20 320,14 360,9 C400,4 430,10 470,7 C510,4 550,2 600,1 L600,72 L0,72Z" fill="url(#ecg2)"/>
      <circle cx="600" cy="1" r="3.5" fill="#3b82f6"/>
    </svg>
  </div>

  <!-- Win Rate + Emotions -->
  <div class="fgrid2" style="margin-bottom:12px">
    <div class="fcard" style="margin:0">
      <div class="fcard-h"><div class="fcard-t">Win Rate / stratégie</div></div>
      <div style="display:flex;gap:14px;align-items:center">
        <svg width="68" height="68" viewBox="0 0 100 100" style="flex-shrink:0">
          <circle cx="50" cy="50" r="38" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="10"/>
          <circle cx="50" cy="50" r="38" fill="none" stroke="#10b981" stroke-width="10" stroke-dasharray="160 79" stroke-linecap="round" transform="rotate(-90 50 50)"/>
          <circle cx="50" cy="50" r="38" fill="none" stroke="#3b82f6" stroke-width="10" stroke-dasharray="57 182" stroke-dashoffset="-160" stroke-linecap="round" transform="rotate(-90 50 50)"/>
          <circle cx="50" cy="50" r="38" fill="none" stroke="#f59e0b" stroke-width="10" stroke-dasharray="22 217" stroke-dashoffset="-217" stroke-linecap="round" transform="rotate(-90 50 50)"/>
          <text x="50" y="55" text-anchor="middle" font-family="Syne,sans-serif" font-weight="700" font-size="16" fill="#e2eaf5">67%</text>
        </svg>
        <div style="flex:1;display:flex;flex-direction:column;gap:7px;font-size:11px">
          <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:#10b981;flex-shrink:0"></div>Breakout<span style="margin-left:auto;font-family:var(--mono)">74%</span></div>
          <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:#3b82f6;flex-shrink:0"></div>Pullback<span style="margin-left:auto;font-family:var(--mono)">62%</span></div>
          <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:#f59e0b;flex-shrink:0"></div>Range<span style="margin-left:auto;font-family:var(--mono)">58%</span></div>
          <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:#ef4444;flex-shrink:0"></div>Reversal<span style="margin-left:auto;font-family:var(--mono)">41%</span></div>
        </div>
      </div>
    </div>

    <div class="fcard" style="margin:0">
      <div class="fcard-h"><div class="fcard-t">États émotionnels</div></div>
      <div style="display:flex;flex-direction:column;gap:9px">
        <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😤 Revenge</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">23%</span></div><div style="height:5px;background:rgba(255,255,255,0.06);border-radius:3px"><div style="width:23%;height:100%;background:#ef4444;border-radius:3px"></div></div></div>
        <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😰 Stress</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">31%</span></div><div style="height:5px;background:rgba(255,255,255,0.06);border-radius:3px"><div style="width:31%;height:100%;background:#f59e0b;border-radius:3px"></div></div></div>
        <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😌 Confiant</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">68%</span></div><div style="height:5px;background:rgba(255,255,255,0.06);border-radius:3px"><div style="width:68%;height:100%;background:#3b82f6;border-radius:3px"></div></div></div>
        <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>🎯 Focus</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">52%</span></div><div style="height:5px;background:rgba(255,255,255,0.06);border-radius:3px"><div style="width:52%;height:100%;background:#10b981;border-radius:3px"></div></div></div>
      </div>
    </div>
  </div>

  <!-- Derniers trades -->
  <div style="display:flex;flex-direction:column;gap:5px">
    <div style="display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--b);border-radius:8px;padding:9px 12px;font-size:11px">
      <span style="background:rgba(16,185,129,.12);color:#10b981;font-family:var(--mono);font-size:9px;padding:2.5px 7px;border-radius:4px;flex-shrink:0;font-weight:700">LONG</span>
      <span style="color:#60a5fa;font-family:var(--mono);min-width:65px;font-weight:500">BTC/USDT</span>
      <span style="color:var(--txt3);flex:1;font-size:10px">Breakout · London</span>
      <span style="font-size:12px">😌</span>
      <span style="color:#10b981;font-family:var(--mono);font-weight:600;font-size:12px">+$400</span>
    </div>
    <div style="display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--b);border-radius:8px;padding:9px 12px;font-size:11px">
      <span style="background:rgba(239,68,68,.12);color:#ef4444;font-family:var(--mono);font-size:9px;padding:2.5px 7px;border-radius:4px;flex-shrink:0;font-weight:700">SHORT</span>
      <span style="color:#60a5fa;font-family:var(--mono);min-width:65px;font-weight:500">EUR/USD</span>
      <span style="color:var(--txt3);flex:1;font-size:10px">Pullback · NY</span>
      <span style="font-size:12px">😤</span>
      <span style="color:#ef4444;font-family:var(--mono);font-weight:600;font-size:12px">-$280</span>
    </div>
    <div style="display:flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--b);border-radius:8px;padding:9px 12px;font-size:11px">
      <span style="background:rgba(16,185,129,.12);color:#10b981;font-family:var(--mono);font-size:9px;padding:2.5px 7px;border-radius:4px;flex-shrink:0;font-weight:700">LONG</span>
      <span style="color:#60a5fa;font-family:var(--mono);min-width:65px;font-weight:500">ETH/USDT</span>
      <span style="color:var(--txt3);flex:1;font-size:10px">Range · Asian</span>
      <span style="font-size:12px">🎯</span>
      <span style="color:#10b981;font-family:var(--mono);font-weight:600;font-size:12px">+$620</span>
    </div>
  </div>
</div>

<style>
  .fdash-topbar {
    display: flex; align-items: flex-start;
    justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1px solid var(--b);
    margin-bottom: 20px;
  }
  .fdash-title { font-family: var(--disp); font-size: 20px; font-weight: 700; letter-spacing: -.3px; }
  .fdash-sub { font-size: 12px; color: var(--txt3); margin-top: 4px; }
</style>
