<section class="comp-section" id="compare">
  <div style="max-width:1100px;margin:0 auto">
    <div class="reveal" style="text-align:center">
      <span class="sec-label">Comparaison</span>
      <h2>Pourquoi MyTradingCoach <em>plutôt que</em> les autres ?</h2>
      <p class="sec-sub" style="margin:0 auto;text-align:center;max-width:500px">Les autres journaux de trading analysent après. MTC supervise avant, pendant et après.</p>
    </div>
    <div class="reveal">
      <div class="table-wrapper">
        <table class="comp-table">
          <thead>
            <tr>
              <th style="text-align:left">Fonctionnalité</th>
              <th class="hl">MyTradingCoach</th>
              <th>TraderSync</th>
              <th>TradesViz</th>
              <th>Edgely</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Journal de trading</td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td></tr>
            <tr><td>Analytics avancés</td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td></tr>
            <tr><td>Tracking émotionnel</td><td><span class="comp-yes">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
            <tr><td>Coach IA conversationnel</td><td><span class="comp-yes">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
            <tr style="background:rgba(34,211,238,.02)"><td style="font-weight:500;color:var(--txt)">Weekly Debrief IA automatique</td><td><span class="comp-yes" style="color:var(--pulse)">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
            <tr><td>Pré-session matin <span class="comp-new">NEW</span></td><td><span class="comp-yes" style="color:var(--pulse)">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
            <tr><td>Session live + trade rapide <span class="comp-new">NEW</span></td><td><span class="comp-yes" style="color:var(--pulse)">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
            <tr><td>Calendrier éco IA filtré <span class="comp-new">NEW</span></td><td><span class="comp-yes" style="color:var(--pulse)">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
            <tr><td>Recap journalier email 17h30 <span class="comp-new">NEW</span></td><td><span class="comp-yes" style="color:var(--pulse)">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
            <tr><td>Import CSV universel (broker-agnostic)</td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-no">–</span></td></tr>
            <tr><td>Hébergé en France 🇫🇷</td><td><span class="comp-yes">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
            <tr><td>Prix mensuel</td><td><span class="comp-price-hl">dès 39 €/mois</span></td><td><span class="comp-price">30–80 $</span></td><td><span class="comp-price">10–29 $</span></td><td><span class="comp-price">~€15</span></td></tr>
          </tbody>
        </table>
      </div>
      <p class="comp-note">Données basées sur les fonctionnalités publiquement documentées · Mise à jour mai 2026</p>
    </div>
  </div>
</section>

<style>
  .comp-section {
    background: var(--bg2);
    border-top: 1px solid var(--b);
  }

  .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-top: 40px;
    border-radius: 12px;
    border: 1px solid var(--b);
  }

  .comp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .comp-table th {
    padding: 14px 18px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--txt3);
    text-align: center;
    text-transform: uppercase;
    border-bottom: 1px solid var(--b);
    background: var(--card);
  }
  .comp-table th:first-child { text-align: left; }
  .comp-table th.hl { color: var(--pulse); }

  .comp-table td {
    padding: 12px 18px;
    border-bottom: 1px solid rgba(99,155,255,.05);
    color: var(--txt2);
    text-align: center;
  }
  .comp-table td:first-child { text-align: left; color: var(--txt); font-weight: 400; }
  .comp-table tr:last-child td { border-bottom: none; }
  .comp-table tr:hover td { background: rgba(99,155,255,.02); }

  .comp-yes { color: var(--green); font-size: 14px; }
  .comp-no  { color: var(--txt3); }
  .comp-price { font-family: var(--mono); font-size: 12px; }
  .comp-price-hl { font-family: var(--mono); font-size: 13px; font-weight: 600; color: var(--pulse); }
  .comp-new {
    font-size: 9px;
    background: rgba(245,158,11,.1);
    color: var(--yel);
    border: 1px solid rgba(245,158,11,.2);
    padding: 2px 6px;
    border-radius: 3px;
    font-family: var(--mono);
    font-weight: 700;
  }

  .comp-note {
    font-size: 11px;
    color: var(--txt3);
    font-family: var(--mono);
    margin-top: 14px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .comp-section { padding: 64px 16px; }
    .comp-table { font-size: 12px; min-width: 560px; }
    .comp-table th, .comp-table td { padding: 10px 12px; }
    .table-wrapper { margin-top: 28px; border-radius: 8px; }
  }
</style>
