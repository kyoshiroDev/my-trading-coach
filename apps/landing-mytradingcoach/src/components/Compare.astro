<section class="comp-section" id="compare">
  <div style="max-width:1100px;margin:0 auto">
    <div class="reveal" style="text-align:center">
      <span class="sec-label">Comparaison</span>
      <h2>Pourquoi MyTradingCoach <em>plutôt que</em> les autres ?</h2>
      <p class="sec-sub" style="margin:0 auto;text-align:center">On ne prétend pas être le meilleur sur tout. On est le seul à combiner journal, coach IA et debrief hebdomadaire à ce prix.</p>
    </div>
    <div class="reveal">
      <div class="table-wrapper">
      <table class="comp-table">
        <thead>
          <tr>
            <th>Fonctionnalité</th>
            <th class="hl">MyTradingCoach</th>
            <th>TraderSync</th>
            <th>TradesViz</th>
            <th>Edgely</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Journal de trading</td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td></tr>
          <tr><td>Analytics avancés</td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td></tr>
          <tr><td>Tracking émotionnel</td><td><span class="comp-yes">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
          <tr><td>Coach IA conversationnel</td><td><span class="comp-yes">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
          <tr style="background:rgba(34,211,238,.02)"><td style="font-weight:500;color:var(--txt)">Weekly Debrief IA automatique</td><td><span class="comp-yes" style="color:var(--pulse)">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
          <tr><td>Import broker automatique</td><td><span class="comp-soon">Bientôt</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-yes">✓</span></td><td><span class="comp-no">–</span></td></tr>
          <tr><td>Hébergé en France 🇫🇷</td><td><span class="comp-yes">✓</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td><td><span class="comp-no">–</span></td></tr>
          <tr><td>Prix mensuel</td><td><span class="comp-price-hl">39 €/mois</span></td><td><span class="comp-price">30–80 $</span></td><td><span class="comp-price">10–29 $</span></td><td><span class="comp-price">~€15</span></td></tr>
        </tbody>
      </table>
      </div>
      <p class="table-scroll-hint">← Fais défiler pour voir la comparaison →</p>
      <p class="comp-note">Données basées sur les fonctionnalités publiquement documentées. Mise à jour mars 2026.</p>
    </div>

    <!-- Layout mobile vertical -->
    <div class="comp-mobile reveal">
      <div class="comp-row-mobile"><div class="comp-feat">Journal de trading</div><div class="comp-vals"><div class="comp-val"><span class="comp-brand-lbl">MTC</span><span class="comp-yes">✓</span></div><div class="comp-val"><span class="comp-brand-lbl">TraderSync</span><span class="comp-yes">✓</span></div></div></div>
      <div class="comp-row-mobile"><div class="comp-feat">Analytics avancés</div><div class="comp-vals"><div class="comp-val"><span class="comp-brand-lbl">MTC</span><span class="comp-yes">✓</span></div><div class="comp-val"><span class="comp-brand-lbl">TraderSync</span><span class="comp-yes">✓</span></div></div></div>
      <div class="comp-row-mobile"><div class="comp-feat">Tracking émotionnel</div><div class="comp-vals"><div class="comp-val"><span class="comp-brand-lbl">MTC</span><span class="comp-yes">✓</span></div><div class="comp-val"><span class="comp-brand-lbl">TraderSync</span><span class="comp-no">–</span></div></div></div>
      <div class="comp-row-mobile"><div class="comp-feat">Coach IA conversationnel</div><div class="comp-vals"><div class="comp-val"><span class="comp-brand-lbl">MTC</span><span class="comp-yes">✓</span></div><div class="comp-val"><span class="comp-brand-lbl">TraderSync</span><span class="comp-no">–</span></div></div></div>
      <div class="comp-row-mobile"><div class="comp-feat" style="font-weight:500;color:var(--txt)">Weekly Debrief IA auto</div><div class="comp-vals"><div class="comp-val"><span class="comp-brand-lbl">MTC</span><span class="comp-yes" style="color:var(--pulse)">✓</span></div><div class="comp-val"><span class="comp-brand-lbl">TraderSync</span><span class="comp-no">–</span></div></div></div>
      <div class="comp-row-mobile"><div class="comp-feat">Hébergé en France 🇫🇷</div><div class="comp-vals"><div class="comp-val"><span class="comp-brand-lbl">MTC</span><span class="comp-yes">✓</span></div><div class="comp-val"><span class="comp-brand-lbl">TraderSync</span><span class="comp-no">–</span></div></div></div>
      <div class="comp-price-mobile">
        <div class="comp-price-col mtc"><span>MyTradingCoach</span><strong>39 €/mois</strong></div>
        <div class="comp-price-col"><span>TraderSync</span><strong>30–80 $</strong></div>
      </div>
      <p class="comp-note" style="padding:0 0 4px">Données basées sur les fonctionnalités publiques. Mars 2026.</p>
    </div>
  </div>
</section>

<style>
  .comp-section {
    background: var(--bg2);
    border-top: 1px solid var(--b);
  }

  .comp-table {
    width: 100%;
    border-collapse: collapse;
    max-width: 900px;
    margin: 52px auto 0;
  }

  .comp-table th {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--txt3);
    text-transform: uppercase;
    letter-spacing: .8px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--b);
    font-weight: 400;
    text-align: center;
  }

  .comp-table th:first-child { text-align: left; }
  .comp-table th.hl { color: var(--blue2); }

  .comp-table td {
    padding: 12px 14px;
    font-size: 13px;
    color: var(--txt2);
    border-bottom: 1px solid rgba(99,155,255,.06);
    text-align: center;
  }

  .comp-table td:first-child { text-align: left; color: var(--txt); }
  .comp-table tr:last-child td { border: none; }
  .comp-table tr:hover td { background: rgba(59,130,246,.02); }

  .comp-yes { color: var(--green); font-size: 15px; }
  .comp-no { color: var(--txt3); font-size: 15px; }
  .comp-soon { color: var(--txt3); font-size: 11px; font-family: var(--mono); }
  .comp-price-hl { color: var(--green); font-family: var(--mono); font-weight: 600; }
  .comp-price { color: var(--txt3); font-family: var(--mono); font-size: 12px; }

  .comp-note {
    text-align: center;
    font-size: 11px;
    color: var(--txt3);
    margin-top: 12px;
    font-family: var(--mono);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 12px;
  }

  .table-scroll-hint {
    display: none;
    text-align: center;
    font-size: 11px;
    color: var(--txt3);
    margin-top: 8px;
    font-family: var(--mono);
  }

  /* Mobile vertical layout */
  .comp-mobile { display: none; }

  @media (max-width: 767px) {
    /* Masquer le tableau desktop */
    .table-wrapper, .table-scroll-hint { display: none; }

    /* Afficher layout vertical */
    .comp-mobile { display: flex; flex-direction: column; gap: 8px; padding: 0 16px; margin-top: 32px; }

    .comp-row-mobile { background: var(--card); border: 1px solid var(--b); border-radius: 10px; padding: 12px 14px; }
    .comp-feat { font-size: 13px; font-weight: 400; color: var(--txt2); margin-bottom: 8px; }
    .comp-vals { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .comp-val { display: flex; align-items: center; justify-content: space-between; background: var(--bg3); border-radius: 6px; padding: 6px 10px; }
    .comp-brand-lbl { font-size: 10px; font-family: var(--mono); color: var(--txt3); }

    .comp-price-mobile { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 4px; }
    .comp-price-col { background: var(--card); border: 1px solid var(--b); border-radius: 10px; padding: 12px 14px; display: flex; flex-direction: column; align-items: center; gap: 4px; text-align: center; }
    .comp-price-col span { font-size: 10px; color: var(--txt3); font-family: var(--mono); }
    .comp-price-col strong { font-size: 16px; font-weight: 700; }
    .comp-price-col.mtc strong { color: var(--blue2); }
  }
</style>
