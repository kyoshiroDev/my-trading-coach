<nav>
  <a href="/" class="nav-logo">
    <img src="/icon/logo-navbar.svg" alt="MyTradingCoach — Journal de trading IA" height="32" style="display:block" />
  </a>
  <ul class="nav-links">
    <li><a href="#features">Fonctionnalités</a></li>
    <li><a href="#showcase">Aperçu</a></li>
    <li><a href="#debrief">Debrief IA</a></li>
    <li><a href="#pricing">Tarifs</a></li>
    <li><a href="https://app.mytradingcoach.app/register" class="nav-cta">Essayer gratuitement →</a></li>
  </ul>
  <button class="nav-mobile-btn" aria-label="Menu">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>
</nav>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 60px;
    padding: 0 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(6,9,15,0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--b);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: var(--txt);
    flex-shrink: 0;
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-size: 13px;
    color: var(--txt2);
    text-decoration: none;
    transition: color .2s;
  }

  .nav-links a:hover { color: var(--txt); }

  .nav-cta {
    background: var(--blue) !important;
    color: #fff !important;
    padding: 7px 16px;
    border-radius: 7px;
    font-weight: 500 !important;
    font-size: 13px !important;
    box-shadow: 0 0 20px rgba(59,130,246,.3);
    transition: all .2s !important;
  }

  .nav-cta:hover {
    background: var(--blue2) !important;
    box-shadow: 0 0 30px rgba(59,130,246,.5) !important;
    transform: translateY(-1px);
  }

  .nav-mobile-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--b);
    border-radius: 6px;
    padding: 6px 8px;
    color: var(--txt2);
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .nav-links { display: flex; }
    .nav-mobile-btn { display: none; }
  }
</style>
