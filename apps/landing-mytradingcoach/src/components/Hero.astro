---
---
<section class="hero">
  <div class="pulse-ring"></div>
  <div class="pulse-ring"></div>
  <div class="pulse-ring"></div>

  <div class="hero-badge">
    <div class="badge-dot"></div>
    Journal de trading · Coach IA · Analyse émotionnelle
  </div>

  <h1>
    Tu sais trader.<br>
    <em>Le problème,</em><br>
    <span class="line-pulse">c'est toi.</span>
  </h1>

  <p class="hero-sub">
    MyTradingCoach identifie tes <strong>patterns émotionnels</strong> et te dit exactement
    quand et pourquoi tu dérailles — chaque semaine, automatiquement.
  </p>

  <div class="hero-actions">
    <a href="https://app.mytradingcoach.app/register" class="btn-primary">
      Commencer gratuitement
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
    <a href="#debrief" class="btn-secondary">Voir le debrief IA →</a>
  </div>

  <div class="hero-social-proof">
    <div class="avatars">
      <div class="av" style="background:linear-gradient(135deg,#3b82f6,#8b5cf6)">A</div>
      <div class="av" style="background:linear-gradient(135deg,#10b981,#3b82f6)">M</div>
      <div class="av" style="background:linear-gradient(135deg,#f59e0b,#ef4444)">K</div>
      <div class="av" style="background:linear-gradient(135deg,#8b5cf6,#ec4899)">L</div>
      <div class="av" style="background:linear-gradient(135deg,#06b6d4,#3b82f6)">R</div>
    </div>
    <span>+247 traders actifs · ★ 4.8/5</span>
  </div>

  <!-- Dashboard mock -->
  <div class="hero-visual" style="margin-top:60px">
    <div class="dashboard-mock">
      <div class="mock-bar">
        <div class="mock-dot" style="background:#f43f5e"></div>
        <div class="mock-dot" style="background:#fbbf24"></div>
        <div class="mock-dot" style="background:#10b981"></div>
        <span style="font-size:11px;color:var(--text3);margin-left:8px;font-family:var(--mono)">MyTradingCoach — Dashboard</span>
      </div>
      <div class="mock-inner">
        <div class="mock-sidebar">
          <div style="font-size:10px;color:var(--text3);font-family:var(--mono);padding:8px 8px 4px;letter-spacing:0.8px;text-transform:uppercase">Menu</div>
          <div class="mock-nav-item active">⬛ Dashboard</div>
          <div class="mock-nav-item">📋 Journal</div>
          <div class="mock-nav-item">📊 Analytics</div>
          <div style="margin-top:8px;font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.8px;padding:0 10px">Premium</div>
          <div class="mock-nav-item">🤖 IA Insights</div>
          <div class="mock-nav-item">📅 Debrief</div>
          <div class="mock-nav-item">🏆 Scoring</div>
        </div>
        <div class="mock-content">
          <div class="mock-stats">
            <div class="mock-stat">
              <div class="mock-stat-label">P&amp;L Total</div>
              <div class="mock-stat-val" style="color:#10b981">+$8.4k</div>
            </div>
            <div class="mock-stat">
              <div class="mock-stat-label">Win Rate</div>
              <div class="mock-stat-val" style="color:#60a5fa">67%</div>
            </div>
            <div class="mock-stat">
              <div class="mock-stat-label">Drawdown</div>
              <div class="mock-stat-val" style="color:#f43f5e">-$1.2k</div>
            </div>
            <div class="mock-stat">
              <div class="mock-stat-label">Trades</div>
              <div class="mock-stat-val">142</div>
            </div>
          </div>
          <div class="mock-chart">
            <div style="font-size:10px;font-family:var(--mono);color:var(--text3);margin-bottom:8px">EQUITY CURVE</div>
            <svg class="chart-line" height="60" viewBox="0 0 400 60" preserveAspectRatio="none">
              <defs>
                <linearGradient id="cg" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.3"/>
                  <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="M0,55 C30,48 50,42 70,38 C90,34 110,30 130,25 C150,20 160,28 180,22 C200,16 220,10 240,8 C260,6 270,14 290,10 C310,6 330,4 360,3 C380,2 395,2 400,2" fill="none" stroke="#3b82f6" stroke-width="2"/>
              <path d="M0,55 C30,48 50,42 70,38 C90,34 110,30 130,25 C150,20 160,28 180,22 C200,16 220,10 240,8 C260,6 270,14 290,10 C310,6 330,4 360,3 C380,2 395,2 400,2 L400,60 L0,60Z" fill="url(#cg)"/>
              <circle cx="400" cy="2" r="4" fill="#3b82f6"/>
            </svg>
          </div>
          <div class="mock-trades">
            <div class="mock-trade">
              <div class="mock-side l">LONG</div>
              <span style="font-family:var(--mono);color:var(--blue2);font-size:11px">BTC/USDT</span>
              <span style="color:var(--text3);flex:1">Breakout · London</span>
              <span style="color:#10b981;font-family:var(--mono)">+$1 400</span>
              <span style="font-size:13px">😌</span>
            </div>
            <div class="mock-trade">
              <div class="mock-side s">SHORT</div>
              <span style="font-family:var(--mono);color:var(--blue2);font-size:11px">EUR/USD</span>
              <span style="color:var(--text3);flex:1">Pullback · NY</span>
              <span style="color:#f43f5e;font-family:var(--mono)">-$280</span>
              <span style="font-size:13px">😤</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100px 5% 80px;
    position: relative;
    text-align: center;
    overflow: hidden;
  }

  /* Radial glow background */
  .hero::after {
    content: '';
    position: absolute;
    top: 20%; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 500px;
    background: radial-gradient(ellipse, rgba(59,130,246,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Pulse ring animation */
  .pulse-ring {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 600px; height: 600px;
    border: 1px solid rgba(34,211,238,0.06);
    border-radius: 50%;
    animation: ringPulse 4s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }

  .pulse-ring:nth-child(2) {
    width: 900px; height: 900px;
    animation-delay: 1s;
    border-color: rgba(34,211,238,0.04);
  }

  .pulse-ring:nth-child(3) {
    width: 1200px; height: 1200px;
    animation-delay: 2s;
    border-color: rgba(34,211,238,0.02);
  }

  @keyframes ringPulse {
    0%, 100% { opacity: 1; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: 0.5; transform: translate(-50%,-50%) scale(1.05); }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(34,211,238,0.08);
    border: 1px solid rgba(34,211,238,0.2);
    color: var(--pulse);
    font-size: 12px;
    font-family: var(--mono);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 32px;
    letter-spacing: 0.5px;
    animation: fadeUp 0.6s ease forwards;
    position: relative;
    z-index: 1;
  }

  .badge-dot {
    width: 6px; height: 6px;
    background: var(--pulse);
    border-radius: 50%;
    animation: blink 2s ease infinite;
    flex-shrink: 0;
  }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

  h1 {
    font-size: clamp(42px, 7vw, 88px);
    font-weight: 800;
    letter-spacing: -3px;
    line-height: 0.95;
    margin-bottom: 28px;
    animation: fadeUp 0.6s 0.1s ease both;
    max-width: 900px;
    font-family: var(--display);
    color: var(--text);
    position: relative;
    z-index: 1;
  }

  h1 em {
    font-style: italic;
    font-family: var(--serif);
    font-weight: 400;
    color: var(--blue2);
    letter-spacing: -1px;
  }

  .line-pulse {
    display: block;
    background: linear-gradient(90deg, var(--blue2), var(--pulse));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(16px, 2vw, 20px);
    color: var(--text2);
    font-weight: 300;
    max-width: 560px;
    line-height: 1.6;
    margin-bottom: 48px;
    animation: fadeUp 0.6s 0.2s ease both;
    position: relative;
    z-index: 1;
  }

  .hero-sub strong { color: var(--text); font-weight: 500; }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    animation: fadeUp 0.6s 0.3s ease both;
    margin-bottom: 32px;
    position: relative;
    z-index: 1;
  }

  .btn-primary {
    background: var(--blue);
    color: white;
    padding: 14px 28px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 0 30px rgba(59,130,246,0.4);
    transition: all 0.2s;
    font-family: var(--display);
  }

  .btn-primary:hover {
    background: var(--blue2);
    transform: translateY(-2px);
    box-shadow: 0 0 50px rgba(59,130,246,0.6);
  }

  .btn-secondary {
    color: var(--text2);
    padding: 14px 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 400;
    text-decoration: none;
    border: 1px solid var(--border2);
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-secondary:hover { color: var(--text); border-color: var(--blue); background: rgba(59,130,246,0.05); }

  .hero-social-proof {
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 13px;
    color: var(--text3);
    animation: fadeUp 0.6s 0.4s ease both;
    margin-bottom: 0;
    position: relative;
    z-index: 1;
  }

  .avatars { display: flex; }

  .av {
    width: 28px; height: 28px;
    border-radius: 50%;
    border: 2px solid var(--bg);
    margin-left: -8px;
    font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
    color: white;
  }

  .av:first-child { margin-left: 0; }

  /* ─── Dashboard mock ─── */
  .hero-visual {
    width: 100%;
    max-width: 900px;
    animation: fadeUp 0.8s 0.5s ease both;
    position: relative;
    z-index: 1;
  }

  .dashboard-mock {
    background: var(--card);
    border: 1px solid var(--border2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 40px 120px rgba(0,0,0,0.8), 0 0 0 1px rgba(56,139,255,0.08);
  }

  .mock-bar {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mock-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  .mock-inner {
    display: grid;
    grid-template-columns: 180px 1fr;
    height: 380px;
  }

  .mock-sidebar {
    background: var(--bg2);
    border-right: 1px solid var(--border);
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mock-nav-item {
    padding: 8px 10px;
    border-radius: 6px;
    font-size: 12px;
    color: var(--text3);
    display: flex;
    align-items: center;
    gap: 8px;
    text-align: left;
  }

  .mock-nav-item.active {
    background: rgba(59,130,246,0.12);
    color: var(--blue2);
  }

  .mock-content { padding: 20px; overflow: hidden; }

  .mock-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }

  .mock-stat {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px;
  }

  .mock-stat-label {
    font-size: 9px;
    font-family: var(--mono);
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 6px;
  }

  .mock-stat-val {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -1px;
    font-family: var(--mono);
    color: var(--text);
  }

  .mock-chart {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px;
    margin-bottom: 12px;
    height: 110px;
    position: relative;
    overflow: hidden;
  }

  .chart-line {
    position: absolute;
    bottom: 20px; left: 14px; right: 14px;
  }

  .mock-trades { display: flex; flex-direction: column; gap: 6px; }

  .mock-trade {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 11px;
  }

  .mock-side {
    font-size: 9px;
    font-family: var(--mono);
    padding: 2px 6px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .mock-side.l { background: rgba(16,185,129,0.12); color: #10b981; }
  .mock-side.s { background: rgba(244,63,94,0.12); color: #f43f5e; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
