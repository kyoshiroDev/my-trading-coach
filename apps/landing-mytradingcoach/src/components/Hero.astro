          <div class="fcard">
            <div class="fcard-h"><div class="fcard-t">Equity Curve</div><div style="display:flex;gap:10px"><span style="font-size:10px;color:var(--blue2);font-family:var(--mono);cursor:pointer">3M</span><span style="font-size:10px;color:var(--txt3);font-family:var(--mono)">All</span></div></div>
            <svg width="100%" height="80" viewBox="0 0 600 80" preserveAspectRatio="none">
              <defs><linearGradient id="cg2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#3b82f6" stop-opacity=".25"/><stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/></linearGradient></defs>
              <path d="M0,72 C40,64 70,56 100,50 C130,44 155,38 185,30 C215,22 235,34 260,26 C285,18 310,12 340,9 C370,6 390,14 420,10 C450,6 480,4 520,3 C550,2 575,2 600,2" fill="none" stroke="#3b82f6" stroke-width="2"/>
              <path d="M0,72 C40,64 70,56 100,50 C130,44 155,38 185,30 C215,22 235,34 260,26 C285,18 310,12 340,9 C370,6 390,14 420,10 C450,6 480,4 520,3 C550,2 575,2 600,2 L600,80 L0,80Z" fill="url(#cg2)"/>
              <circle cx="600" cy="2" r="4" fill="#3b82f6"/>
            </svg>
          </div>
          <div class="fgrid2">
            <div class="fcard" style="margin:0">
              <div class="fcard-h"><div class="fcard-t">Win Rate par stratégie</div></div>
              <div style="display:flex;gap:14px;align-items:center">
                <svg width="72" height="72" viewBox="0 0 100 100"><circle cx="50" cy="50" r="38" fill="none" stroke="#111b2e" stroke-width="10"/><circle cx="50" cy="50" r="38" fill="none" stroke="#10b981" stroke-width="10" stroke-dasharray="160 79" stroke-dashoffset="0" stroke-linecap="round" transform="rotate(-90 50 50)"/><circle cx="50" cy="50" r="38" fill="none" stroke="#3b82f6" stroke-width="10" stroke-dasharray="57 182" stroke-dashoffset="-160" stroke-linecap="round" transform="rotate(-90 50 50)"/><circle cx="50" cy="50" r="38" fill="none" stroke="#ef4444" stroke-width="10" stroke-dasharray="22 217" stroke-dashoffset="-217" stroke-linecap="round" transform="rotate(-90 50 50)"/><text x="50" y="54" text-anchor="middle" font-family="Inter" font-weight="700" font-size="16" fill="#e2eaf5">67%</text></svg>
                <div style="flex:1;display:flex;flex-direction:column;gap:7px;font-size:11px">
                  <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:var(--green);flex-shrink:0"></div>Breakout<span style="margin-left:auto;font-family:var(--mono);color:var(--txt)">74%</span></div>
                  <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:var(--blue);flex-shrink:0"></div>Pullback<span style="margin-left:auto;font-family:var(--mono);color:var(--txt)">62%</span></div>
                  <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:var(--yel);flex-shrink:0"></div>Range<span style="margin-left:auto;font-family:var(--mono);color:var(--txt)">58%</span></div>
                  <div style="display:flex;align-items:center;gap:6px;color:var(--txt2)"><div style="width:7px;height:7px;border-radius:50%;background:var(--red);flex-shrink:0"></div>Reversal<span style="margin-left:auto;font-family:var(--mono);color:var(--txt)">41%</span></div>
                </div>
              </div>
            </div>
            <div class="fcard" style="margin:0">
              <div class="fcard-h"><div class="fcard-t">États émotionnels</div></div>
              <div style="display:flex;flex-direction:column;gap:10px">
                <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😤 Revenge</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">23%</span></div><div style="height:5px;background:var(--bg3);border-radius:3px"><div style="width:23%;height:100%;background:var(--red);border-radius:3px"></div></div></div>
                <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😰 Stress</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">31%</span></div><div style="height:5px;background:var(--bg3);border-radius:3px"><div style="width:31%;height:100%;background:var(--yel);border-radius:3px"></div></div></div>
                <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>😌 Confiant</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">68%</span></div><div style="height:5px;background:var(--bg3);border-radius:3px"><div style="width:68%;height:100%;background:var(--blue);border-radius:3px"></div></div></div>
                <div><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--txt2);margin-bottom:4px"><span>🎯 Focus</span><span style="font-family:var(--mono);font-size:10px;color:var(--txt3)">52%</span></div><div style="height:5px;background:var(--bg3);border-radius:3px"><div style="width:52%;height:100%;background:var(--green);border-radius:3px"></div></div></div>
              </div>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:6px;margin-top:12px">
            <div style="display:flex;align-items:center;gap:9px;background:var(--bg3);border:1px solid var(--b);border-radius:8px;padding:9px 12px;font-size:11px">
              <span style="background:rgba(16,185,129,.12);color:var(--green);font-family:var(--mono);font-size:9px;padding:2.5px 6px;border-radius:3px;flex-shrink:0">LONG</span>
              <span style="color:var(--blue2);font-family:var(--mono);min-width:60px;font-weight:500">BTC/USDT</span>
              <span style="color:var(--txt3);flex:1;font-size:10px">Breakout · London</span>
              <span style="font-size:12px">😌</span>
              <span style="color:var(--green);font-family:var(--mono);font-weight:500;font-size:12px">+$1 400</span>
            </div>
            <div style="display:flex;align-items:center;gap:9px;background:var(--bg3);border:1px solid var(--b);border-radius:8px;padding:9px 12px;font-size:11px">
              <span style="background:rgba(239,68,68,.12);color:var(--red);font-family:var(--mono);font-size:9px;padding:2.5px 6px;border-radius:3px;flex-shrink:0">SHORT</span>
              <span style="color:var(--blue2);font-family:var(--mono);min-width:60px;font-weight:500">EUR/USD</span>
              <span style="color:var(--txt3);flex:1;font-size:10px">Pullback · NY</span>
              <span style="font-size:12px">😤</span>
              <span style="color:var(--red);font-family:var(--mono);font-weight:500;font-size:12px">-$280</span>
            </div>
            <div style="display:flex;align-items:center;gap:9px;background:var(--bg3);border:1px solid var(--b);border-radius:8px;padding:9px 12px;font-size:11px">
              <span style="background:rgba(16,185,129,.12);color:var(--green);font-family:var(--mono);font-size:9px;padding:2.5px 6px;border-radius:3px;flex-shrink:0">LONG</span>
              <span style="color:var(--blue2);font-family:var(--mono);min-width:60px;font-weight:500">ETH/USDT</span>
              <span style="color:var(--txt3);flex:1;font-size:10px">Range · Asian</span>
              <span style="font-size:12px">🎯</span>
              <span style="color:var(--green);font-family:var(--mono);font-weight:500;font-size:12px">+$620</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── BANNER ── */
  .banner {
    background: rgba(16,185,129,.06);
    border-bottom: 1px solid rgba(16,185,129,.12);
    padding: 8px 5%;
    text-align: center;
    font-size: 11px;
    color: #10b981;
    font-family: var(--mono);
    letter-spacing: .5px;
    position: relative;
    z-index: 1;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 5% 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 20%; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 400px;
    background: radial-gradient(ellipse, rgba(59,130,246,.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .pulse-ring {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    border: 1px solid rgba(34,211,238,.05);
    border-radius: 50%;
    pointer-events: none;
    animation: rpulse 4s ease-in-out infinite;
  }
  .pulse-ring:nth-child(2) { width:500px; height:500px; }
  .pulse-ring:nth-child(3) { width:800px; height:800px; animation-delay:1.3s; border-color:rgba(34,211,238,.03); }
  .pulse-ring:nth-child(4) { width:1100px; height:1100px; animation-delay:2.6s; border-color:rgba(34,211,238,.02); }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(34,211,238,.07);
    border: 1px solid rgba(34,211,238,.2);
    color: var(--pulse);
    font-size: 11px;
    font-family: var(--mono);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 32px;
    letter-spacing: .4px;
    position: relative;
    z-index: 1;
    animation: fup .6s ease both;
  }

  .bdot {
    width: 6px; height: 6px;
    background: var(--pulse);
    border-radius: 50%;
    animation: blink 2s ease infinite;
    flex-shrink: 0;
  }

  .hero h1 {
    font-family: var(--disp);
    font-size: clamp(40px,7vw,84px);
    font-weight: 700;
    letter-spacing: -1px;
    line-height: .95;
    margin-bottom: 26px;
    position: relative;
    z-index: 1;
    animation: fup .6s .1s ease both;
  }

  .hero h1 em {
    font-style: italic;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    color: var(--blue2);
    letter-spacing: -1px;
  }

  .gline {
    display: block;
    background: linear-gradient(90deg, var(--blue2), var(--pulse));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(15px,2vw,19px);
    color: var(--txt2);
    font-weight: 300;
    max-width: 540px;
    line-height: 1.65;
    margin-bottom: 44px;
    position: relative;
    z-index: 1;
    animation: fup .6s .2s ease both;
  }

  .hero-sub strong { color: var(--txt); font-weight: 500; }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 52px;
    position: relative;
    z-index: 1;
    animation: fup .6s .3s ease both;
  }

  .btn-p {
    background: var(--blue);
    color: #fff;
    padding: 13px 26px;
    border-radius: 9px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 0 28px rgba(59,130,246,.4);
    transition: all .2s;
    border: none;
    cursor: pointer;
    font-family: var(--disp);
  }

  .btn-p:hover { background: var(--blue2); transform: translateY(-2px); box-shadow: 0 0 44px rgba(59,130,246,.55); }

  .btn-s {
    color: var(--txt2);
    padding: 13px 22px;
    border-radius: 9px;
    font-size: 14px;
    text-decoration: none;
    border: 1px solid var(--b2);
    transition: all .2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-s:hover { color: var(--txt); border-color: var(--blue); background: rgba(59,130,246,.05); }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(34,211,238,.06);
    border: 1px solid rgba(34,211,238,.15);
    padding: 7px 15px;
    border-radius: 100px;
    position: relative;
    z-index: 1;
    animation: fup .6s .4s ease both;
  }

  .hero-trust span { font-size: 12px; color: var(--pulse); font-family: var(--mono); letter-spacing: .3px; }

  /* ── APP SCREENSHOT ── */
  .hero-screen {
    width: 100%;
    max-width: 1100px;
    margin-top: 64px;
    position: relative;
    z-index: 1;
    animation: fup .8s .5s ease both;
  }

  .full-screen {
    background: var(--card);
    border: 1px solid var(--b2);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,.6);
  }

  .full-bar {
    background: var(--bg3);
    border-bottom: 1px solid var(--b);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .sdot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .screen-url { font-size: 11px; color: var(--txt3); font-family: var(--mono); }

  .full-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: 480px;
  }

  .full-sidebar {
    background: var(--bg3);
    border-right: 1px solid var(--b);
    padding: 14px 10px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .flogo {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px;
    margin-bottom: 8px;
    border-bottom: 1px solid var(--b);
    padding-bottom: 14px;
  }

  .flogo-ic {
    width: 26px; height: 26px;
    background: linear-gradient(135deg,#3b82f6,#8b5cf6);
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .flogo-txt { font-family: var(--disp); font-size: 13px; font-weight: 700; letter-spacing: -.2px; }
  .flogo-txt span { color: var(--blue2); }

  .fsec { font-size: 9px; font-family: var(--mono); color: var(--txt3); letter-spacing: 1.1px; text-transform: uppercase; padding: 12px 10px 5px; }

  .fnav {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 7px;
    font-size: 12px;
    color: var(--txt3);
    transition: all .15s;
  }

  .fnav:hover { background: rgba(59,130,246,.08); color: var(--txt2); }

  .fnav.act {
    background: rgba(59,130,246,.12);
    color: var(--blue2);
    font-weight: 500;
    position: relative;
  }

  .fnav.act::before {
    content: '';
    position: absolute;
    left: 0; top: 50%;
    transform: translateY(-50%);
    width: 3px; height: 18px;
    background: var(--blue);
    border-radius: 0 3px 3px 0;
  }

  .fbadge {
    margin-left: auto;
    background: linear-gradient(135deg,#3b82f6,#8b5cf6);
    color: #fff;
    font-size: 8px;
    font-family: var(--mono);
    padding: 2px 6px;
    border-radius: 8px;
  }

  .fuser {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-radius: 8px;
    margin-top: auto;
    border-top: 1px solid var(--b);
    padding-top: 14px;
  }

  .favatar {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg,#3b82f6,#8b5cf6);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; font-family: var(--disp);
    flex-shrink: 0;
    color: #fff;
  }

  .funame { font-size: 12px; font-weight: 500; }
  .fuplan { font-size: 9px; font-family: var(--mono); color: var(--yel); letter-spacing: .4px; }

  .full-content { padding: 24px; overflow: hidden; background: var(--bg2); }

  .ftopbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
  .ftopbar h3 { font-family: var(--disp); font-size: 16px; font-weight: 700; letter-spacing: -.3px; }

  .fstats { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-bottom: 16px; }

  .fstat {
    background: var(--bg3);
    border: 1px solid var(--b);
    border-radius: 9px;
    padding: 14px;
    position: relative;
    overflow: hidden;
  }

  .fstat-lbl { font-size: 9px; font-family: var(--mono); color: var(--txt3); letter-spacing: .7px; text-transform: uppercase; margin-bottom: 7px; }
  .fstat-val { font-family: var(--disp); font-size: 22px; font-weight: 700; letter-spacing: -.3px; }
  .fstat-sub { font-size: 10px; color: var(--txt3); margin-top: 5px; display: flex; gap: 5px; }
  .fup { color: var(--green); background: rgba(16,185,129,.1); font-family: var(--mono); font-size: 9px; padding: 1.5px 5px; border-radius: 3px; }
  .fdn { color: var(--red); background: rgba(239,68,68,.1); font-family: var(--mono); font-size: 9px; padding: 1.5px 5px; border-radius: 3px; }

  .text-g { color: var(--green); }
  .text-b { color: var(--blue2); }
  .text-r { color: var(--red); }

