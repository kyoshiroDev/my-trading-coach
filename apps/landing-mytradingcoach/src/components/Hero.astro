---
import MockupShell from './mockup/MockupShell.astro';
import MockupDashboard from './mockup/MockupDashboard.astro';
---

<!-- BANNER -->
<div class="banner">🇫🇷 Fait en France · Indépendant · Sans VC · Tes données ne sont jamais vendues</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="pulse-ring"></div>
  <div class="pulse-ring"></div>
  <div class="pulse-ring"></div>

  <div class="hero-badge">
    <div class="bdot"></div>
    Early access ouvert — Journal IA · Coach · Weekly Debrief
  </div>

  <h1>
    Tu sais trader.<br />
    <em>Le problème,</em><br />
    <span class="gline">c'est toi.</span>
  </h1>

  <p class="hero-sub">
    MyTradingCoach, le <strong>journal de trading crypto et forex</strong> intelligent, identifie tes <strong>patterns émotionnels</strong> et te dit exactement
    quand et pourquoi tu dérailles — chaque semaine, automatiquement.
  </p>

  <div class="hero-actions">
    <a href="https://app.mytradingcoach.app/register" class="btn-p">
      Commencer gratuitement
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <a href="#showcase" class="btn-s">Voir l'app →</a>
  </div>

  <div class="hero-trust">
    <div class="bdot"></div>
    <span>Early access ouvert — sois parmi les premiers traders</span>
  </div>

  <!-- App screenshot -->
  <div class="hero-screen">
    <MockupShell url="app.mytradingcoach.app — Dashboard" active="dashboard" style="border-radius:16px;box-shadow:0 48px 120px rgba(0,0,0,.85),0 0 0 1px rgba(56,139,255,.08)">
      <MockupDashboard />
    </MockupShell>
  </div>
</section>

<style>
  /* ── BANNER ── */
  .banner {
    background: rgba(16,185,129,.06);
    border-bottom: 1px solid rgba(16,185,129,.12);
    padding: 8px 5%;
    text-align: center;
    font-size: 11px;
    color: #10b981;
    font-family: var(--mono);
    letter-spacing: .5px;
    position: relative;
    z-index: 1;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 5% 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 20%; left: 50%;
    transform: translateX(-50%);
    width: 700px; height: 400px;
    background: radial-gradient(ellipse, rgba(59,130,246,.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .pulse-ring {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    border: 1px solid rgba(34,211,238,.05);
    border-radius: 50%;
    pointer-events: none;
    animation: rpulse 4s ease-in-out infinite;
  }
  .pulse-ring:nth-child(2) { width:500px; height:500px; }
  .pulse-ring:nth-child(3) { width:800px; height:800px; animation-delay:1.3s; border-color:rgba(34,211,238,.03); }
  .pulse-ring:nth-child(4) { width:1100px; height:1100px; animation-delay:2.6s; border-color:rgba(34,211,238,.02); }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(34,211,238,.07);
    border: 1px solid rgba(34,211,238,.2);
    color: var(--pulse);
    font-size: 11px;
    font-family: var(--mono);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 32px;
    letter-spacing: .4px;
    position: relative;
    z-index: 1;
    animation: fup .6s ease both;
  }

  .bdot {
    width: 6px; height: 6px;
    background: var(--pulse);
    border-radius: 50%;
    animation: blink 2s ease infinite;
    flex-shrink: 0;
  }

  .hero h1 {
    font-family: var(--disp);
    font-size: clamp(40px,7vw,84px);
    font-weight: 700;
    letter-spacing: -1px;
    line-height: .95;
    margin-bottom: 26px;
    position: relative;
    z-index: 1;
    animation: fup .6s .1s ease both;
  }

  .hero h1 em {
    font-style: italic;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    color: var(--blue2);
    letter-spacing: -1px;
  }

  .gline {
    display: block;
    background: linear-gradient(90deg, var(--blue2), var(--pulse));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(15px,2vw,19px);
    color: var(--txt2);
    font-weight: 300;
    max-width: 540px;
    line-height: 1.65;
    margin-bottom: 44px;
    position: relative;
    z-index: 1;
    animation: fup .6s .2s ease both;
  }

  .hero-sub strong { color: var(--txt); font-weight: 500; }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 52px;
    position: relative;
    z-index: 1;
    animation: fup .6s .3s ease both;
  }

  .btn-p {
    background: var(--blue);
    color: #fff;
    padding: 13px 26px;
    border-radius: 9px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 0 28px rgba(59,130,246,.4);
    transition: all .2s;
    border: none;
    cursor: pointer;
    font-family: var(--disp);
  }

  .btn-p:hover { background: var(--blue2); transform: translateY(-2px); box-shadow: 0 0 44px rgba(59,130,246,.55); }

  .btn-s {
    color: var(--txt2);
    padding: 13px 22px;
    border-radius: 9px;
    font-size: 14px;
    text-decoration: none;
    border: 1px solid var(--b2);
    transition: all .2s;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .btn-s:hover { color: var(--txt); border-color: var(--blue); background: rgba(59,130,246,.05); }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(34,211,238,.06);
    border: 1px solid rgba(34,211,238,.15);
    padding: 7px 15px;
    border-radius: 100px;
    position: relative;
    z-index: 1;
    animation: fup .6s .4s ease both;
  }

  .hero-trust span { font-size: 12px; color: var(--pulse); font-family: var(--mono); letter-spacing: .3px; }

  /* ── APP SCREENSHOT ── */
  .hero-screen {
    width: 100%;
    max-width: 1100px;
    margin-top: 64px;
    position: relative;
    z-index: 1;
    animation: fup .8s .5s ease both;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .hero {
      padding: 100px 16px 60px;
      overflow: visible;
    }

    .hero-badge,
    .hero h1,
    .hero-sub,
    .hero-actions,
    .hero-trust {
      position: relative;
      z-index: 2;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
      width: 100%;
      max-width: 320px;
    }

    .hero-actions a {
      text-align: center;
      justify-content: center;
      width: 100%;
    }

    .hero-screen {
      overflow: hidden;
      margin-top: 40px;
    }
  }
</style>
