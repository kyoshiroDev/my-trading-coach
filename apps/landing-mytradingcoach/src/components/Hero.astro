<style>
  /* ── BANNER ── */
  .banner {
    background: rgba(16,185,129,.06);
    border-bottom: 1px solid rgba(16,185,129,.12);
    padding: 8px 5%;
    text-align: center;
    font-size: 11px;
    color: var(--green);
    font-family: var(--mono);
    letter-spacing: .5px;
    position: relative;
    z-index: 1;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 5% 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: 20%; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 500px;
    background: radial-gradient(ellipse, rgba(59,130,246,.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .pulse-ring {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    border: 1px solid rgba(34,211,238,.05);
    border-radius: 50%;
    pointer-events: none;
    animation: rpulse 4s ease-in-out infinite;
  }
  .pulse-ring:nth-child(2) { width:500px; height:500px; }
  .pulse-ring:nth-child(3) { width:800px; height:800px; animation-delay:1.3s; border-color:rgba(34,211,238,.03); }
  .pulse-ring:nth-child(4) { width:1100px; height:1100px; animation-delay:2.6s; border-color:rgba(34,211,238,.02); }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(34,211,238,.07);
    border: 1px solid rgba(34,211,238,.2);
    color: var(--pulse);
    font-size: 11px;
    font-family: var(--mono);
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 28px;
    letter-spacing: .4px;
    position: relative;
    z-index: 1;
    animation: fup .6s ease both;
  }

  .bdot {
    width: 6px; height: 6px;
    background: var(--pulse);
    border-radius: 50%;
    animation: blink 2s ease infinite;
    flex-shrink: 0;
  }

  .hero-proof {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  .hero-stars { color: var(--yel); font-size: 14px; letter-spacing: 2px; }
  .hero-proof-text { font-size: 13px; color: var(--txt2); font-family: var(--mono); }
  .hero-proof-text strong { color: var(--txt); }

  .hero h1 {
    font-family: var(--disp);
    font-size: clamp(42px,7vw,88px);
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: .92;
    margin-bottom: 24px;
    position: relative;
    z-index: 1;
    animation: fup .6s .1s ease both;
  }

  .hero h1 em {
    font-style: italic;
    font-family: var(--body);
    font-weight: 300;
    color: var(--blue2);
  }

  .gline { display: block; color: var(--pulse); }

  .hero-sub {
    font-size: clamp(15px,2vw,19px);
    color: var(--txt2);
    font-weight: 300;
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
    animation: fup .6s .2s ease both;
  }
  .hero-sub strong { color: var(--txt); font-weight: 500; }

  /* 3 moments inline sous le sub */
  .hero-moments {
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: center;
    margin-bottom: 40px;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
    animation: fup .6s .25s ease both;
  }

  .hero-moment {
    font-size: 12px;
    font-family: var(--mono);
    padding: 4px 10px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-moment.avant  { background: rgba(16,185,129,.08);  color: var(--green); border: 1px solid rgba(16,185,129,.2); }
  .hero-moment.pendant{ background: rgba(59,130,246,.08);  color: var(--blue2); border: 1px solid rgba(59,130,246,.2); }
  .hero-moment.apres  { background: rgba(139,92,246,.08);  color: #a78bfa;      border: 1px solid rgba(139,92,246,.2); }
  .hero-moment-sep    { color: var(--txt3); font-size: 11px; }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
    animation: fup .6s .3s ease both;
  }

  .btn-p {
    background: var(--blue);
    color: #fff;
    padding: 13px 26px;
    border-radius: 9px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 0 28px rgba(59,130,246,.4);
    transition: background .2s, transform .2s, box-shadow .2s;
    border: none;
    cursor: pointer;
    font-family: var(--disp);
  }

  .btn-p:hover { background: var(--blue2); transform: translateY(-2px); box-shadow: 0 0 44px rgba(59,130,246,.55); }

  .hero-cta-main {
    font-size: 16px !important;
    padding: 16px 32px !important;
    box-shadow: 0 0 40px rgba(59,130,246,.5) !important;
  }

  .hero-cta-sub {
    font-size: 12px;
    color: var(--txt3);
    font-family: var(--mono);
    margin: 0;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .hero { padding: 80px 16px 56px; min-height: auto; }
    .hero h1 { font-size: clamp(36px,9vw,52px); letter-spacing: -1px; }
    .hero-sub { font-size: 15px; max-width: 100%; }
    .hero-moments { gap: 4px; }
    .hero-moment { font-size: 11px; padding: 3px 8px; }
    .hero-moment-sep { display: none; }
    .hero-actions { flex-direction: column; align-items: stretch; gap: 10px; padding: 0; }
    .hero-actions a { text-align: center; justify-content: center; width: 100%; }
    .btn-p.hero-cta-main { font-size: 15px !important; padding: 14px 20px !important; }
    .hero-badge { font-size: 10px; padding: 4px 12px; text-align: center; }
    .hero-proof { flex-wrap: wrap; justify-content: center; }
    .pulse-ring { display: none; }
    .hero-moments { flex-direction: column; align-items: center; gap: 6px; }
