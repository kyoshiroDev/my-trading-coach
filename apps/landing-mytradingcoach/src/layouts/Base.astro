---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ═══ SEO PRIMARY ═══ -->
  <title>MyTradingCoach — Journal de Trading IA & Coach</title>
  <meta name="description" content="Journal de trading intelligent avec coach IA. Identifiez vos patterns émotionnels, recevez un debrief hebdomadaire. Gratuit pour démarrer." />
  <link rel="canonical" href="https://mytradingcoach.app" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <meta name="author" content="MyTradingCoach" />
  <meta name="keywords" content="journal de trading, journal trading crypto, journal trading forex, coach trading IA, psychologie trading, weekly debrief trading, tracker trades, améliorer trading" />
  <meta name="geo.region" content="FR" />
  <meta name="language" content="fr" />

  <!-- ═══ OPEN GRAPH ═══ -->
  <meta property="og:title" content="MyTradingCoach — Journal de Trading Intelligent avec Coach IA" />
  <meta property="og:description" content="Identifiez vos patterns émotionnels. Comprenez quand et pourquoi vous déraillez. Debrief IA chaque semaine, automatiquement." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://mytradingcoach.app" />
  <meta property="og:image" content="https://mytradingcoach.app/og-image.svg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="MyTradingCoach" />

  <!-- ═══ TWITTER CARD ═══ -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@mytradingcoach" />
  <meta name="twitter:title" content="MyTradingCoach — Journal de Trading Intelligent avec Coach IA" />
  <meta name="twitter:description" content="Identifiez vos patterns émotionnels. Comprenez quand et pourquoi vous déraillez. Debrief IA chaque semaine." />
  <meta name="twitter:image" content="https://mytradingcoach.app/og-image.svg" />

  <!-- ═══ SCHEMA.ORG JSON-LD ═══ -->
  <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "MyTradingCoach",
        "description": "Journal de trading intelligent avec coach IA et debrief hebdomadaire automatique. Analyse comportementale et émotionnelle pour traders crypto, forex et actions.",
        "url": "https://mytradingcoach.app",
        "applicationCategory": "FinanceApplication",
        "applicationSubCategory": "Trading Journal",
        "operatingSystem": "Web",
        "inLanguage": "fr-FR",
        "offers": [
          { "@type": "Offer", "name": "Gratuit", "price": "0", "priceCurrency": "EUR", "description": "Journal de trading jusqu'à 50 trades par mois" },
          { "@type": "Offer", "name": "Premium", "price": "29", "priceCurrency": "EUR", "billingPeriod": "P1M", "description": "IA Insights, Analytics avancés, Weekly Debrief automatique" }
        ],
        "featureList": [
          "Journal de trading intelligent",
          "Tracking émotionnel par trade",
          "Analyse IA des performances",
          "Weekly Debrief automatique",
          "Coach IA personnel",
          "Analytics avancés",
          "Score trader"
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "MyTradingCoach",
        "url": "https://mytradingcoach.app",
        "inLanguage": "fr-FR",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://mytradingcoach.app/blog?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "MyTradingCoach",
        "url": "https://mytradingcoach.app",
        "logo": "https://mytradingcoach.app/logo.svg",
        "description": "Journal de trading intelligent avec coach IA",
        "foundingLocation": "France",
        "sameAs": ["https://twitter.com/mytradingcoach"]
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "C'est quoi exactement MyTradingCoach ?",
            "acceptedAnswer": { "@type": "Answer", "text": "MyTradingCoach est un journal de trading intelligent. Tu enregistres tes trades et ton état émotionnel, et l'IA analyse tout ça pour identifier tes patterns comportementaux. Chaque dimanche, tu reçois un debrief complet avec 3 objectifs pour la semaine suivante." }
          },
          {
            "@type": "Question",
            "name": "Quels marchés sont supportés ?",
            "acceptedAnswer": { "@type": "Answer", "text": "MyTradingCoach fonctionne pour tous les marchés : crypto (BTC, ETH, SOL), forex (EUR/USD, GBP/USD), actions (AAPL, TSLA) et indices. La saisie est manuelle, pas de connexion broker requise." }
          },
          {
            "@type": "Question",
            "name": "Combien coûte MyTradingCoach ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Plan gratuit (50 trades/mois) et plan Premium à 29€/mois ou 290€/an. Essai Premium gratuit 14 jours, sans CB requise." }
          },
          {
            "@type": "Question",
            "name": "L'IA est-elle vraiment personnalisée ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Oui. L'IA analyse uniquement tes données, pas des moyennes génériques. Plus tu l'utilises, plus les insights sont précis." }
          },
          {
            "@type": "Question",
            "name": "Mes données sont-elles sécurisées ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Tes données sont hébergées sur des serveurs OVH en France, chiffrées au repos et en transit. Nous ne vendons ni ne partageons jamais tes données de trading." }
          }
        ]
      }
    ]
  </script>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#3b82f6" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
  <script>
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if(e.isIntersecting){ e.target.classList.add('vis'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal, .rstag').forEach(el => obs.observe(el));
  </script>
</body>
</html>
