---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogUrl?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "MyTradingCoach — Journal de Trading IA & Coach",
  description = "Journal de trading intelligent avec coach IA. Identifie tes patterns émotionnels, analyse tes performances et reçois ton Weekly Debrief chaque dimanche. Essai gratuit sans CB — hébergé en France 🇫🇷",
  canonical = `https://www.mytradingcoach.app${Astro.url.pathname}`,
  ogUrl = canonical,
  schema,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ═══ SEO PRIMARY ═══ -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <meta name="author" content="MyTradingCoach" />
  <meta name="keywords" content="journal de trading, journal trading crypto, journal trading forex, coach trading IA, psychologie du trading, weekly debrief trading, tracker trades, améliorer trading, carnet de trading, journal trading gratuit" />
  <meta name="geo.region" content="FR" />
  <meta name="language" content="fr" />

  <!-- ═══ OPEN GRAPH ═══ -->
  <meta property="og:title" content="MyTradingCoach — Journal de Trading IA & Coach" />
  <meta property="og:description" content="Journal de trading intelligent avec coach IA. Identifie tes patterns, analyse tes émotions, reçois ton Weekly Debrief chaque dimanche." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={ogUrl} />
  <meta property="og:image" content="https://www.mytradingcoach.app/icon/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="MyTradingCoach" />

  <!-- ═══ TWITTER CARD ═══ -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@mytradingcoach" />
  <meta name="twitter:title" content="MyTradingCoach — Journal de Trading IA" />
  <meta name="twitter:description" content="Journal de trading intelligent avec coach IA. Identifie tes patterns, analyse tes émotions, reçois ton Weekly Debrief chaque dimanche." />
  <meta name="twitter:image" content="https://www.mytradingcoach.app/icon/og-image.png" />

  <!-- ═══ SCHEMA.ORG JSON-LD ═══ -->
  {schema ? (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ) : (
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "MyTradingCoach",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "url": "https://www.mytradingcoach.app",
        "description": "Journal de trading intelligent avec coach IA, tracking émotionnel et Weekly Debrief automatique.",
        "inLanguage": "fr",
        "offers": [
          { "@type": "Offer", "name": "Gratuit", "price": "0", "priceCurrency": "EUR", "description": "50 trades/mois, stats de base, journal complet" },
          { "@type": "Offer", "name": "Premium", "price": "29", "priceCurrency": "EUR", "priceSpecification": { "@type": "UnitPriceSpecification", "price": "29", "priceCurrency": "EUR", "unitCode": "MON" }, "description": "Trades illimités, IA Insights, Weekly Debrief, Analytics avancés" }
        ],
        "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.8", "ratingCount": "24", "bestRating": "5" },
        "featureList": [
          "Journal de trading avec tracking émotionnel",
          "IA Insights powered by Claude",
          "Weekly Debrief automatique chaque dimanche",
          "Analytics avancés — win rate, drawdown, heatmap",
          "Score trader — 5 axes de progression",
          "Hébergé en France"
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "MyTradingCoach",
        "url": "https://www.mytradingcoach.app",
        "logo": "https://www.mytradingcoach.app/icon/og-image.png",
        "contactPoint": { "@type": "ContactPoint", "email": "hello@mytradingcoach.app", "contactType": "customer support", "availableLanguage": "French" },
        "address": { "@type": "PostalAddress", "addressCountry": "FR" },
        "sameAs": []
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "MyTradingCoach",
        "url": "https://www.mytradingcoach.app",
        "inLanguage": "fr",
        "description": "Journal de trading intelligent avec coach IA pour traders crypto et forex"
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "C'est quoi exactement MyTradingCoach ?",
            "acceptedAnswer": { "@type": "Answer", "text": "MyTradingCoach est un journal de trading intelligent. Tu enregistres tes trades et ton état émotionnel, et l'IA analyse tout ça pour identifier tes patterns comportementaux. Chaque dimanche, tu reçois un debrief complet avec 3 objectifs pour la semaine suivante." }
          },
          {
            "@type": "Question",
            "name": "Quels marchés sont supportés ?",
            "acceptedAnswer": { "@type": "Answer", "text": "MyTradingCoach fonctionne pour tous les marchés : crypto (BTC, ETH, SOL...), forex (EUR/USD, GBP/USD...), actions (AAPL, TSLA...) et indices. Tu saisis les données manuellement." }
          },
          {
            "@type": "Question",
            "name": "L'IA est-elle vraiment personnalisée ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Oui. L'IA analyse uniquement tes données — pas des moyennes génériques. Plus tu l'utilises, plus les insights sont précis. Le debrief hebdomadaire référence tes trades spécifiques avec les heures et les montants réels." }
          },
          {
            "@type": "Question",
            "name": "Pourquoi 39 €/mois ?",
            "acceptedAnswer": { "@type": "Answer", "text": "On a voulu un prix accessible pour tous les traders. Si l'IA t'aide à éviter un seul revenge trade à 300 €, MyTradingCoach est rentabilisé pour 8 mois." }
          },
          {
            "@type": "Question",
            "name": "Mes données sont-elles sécurisées ?",
            "acceptedAnswer": { "@type": "Answer", "text": "Tes données sont stockées sur des serveurs OVH en France, chiffrées au repos et en transit. Nous ne vendons ni ne partageons jamais tes données de trading. Tu peux exporter ou supprimer ton compte à tout moment." }
          }
        ]
      }
    ])} />
  )}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/logo.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#3b82f6" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
  <script>
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if(e.isIntersecting){ e.target.classList.add('vis'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal, .rstag').forEach(el => obs.observe(el));
  </script>
</body>
</html>
