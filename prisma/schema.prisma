generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String?
  role        Role      @default(USER)
  plan        Plan      @default(FREE)
  trialEndsAt DateTime?
  trialUsed   Boolean   @default(false)

  // ── Reset mot de passe ──────────────────────────────────────────────────
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  // ── Stripe ──────────────────────────────────────
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripePriceId            String?
  stripeInterval           String? // 'month' | 'year'
  stripeCurrentPeriodEnd   DateTime?
  stripeSubscriptionStatus String? // 'active' | 'trialing' | 'past_due' | 'unpaid' | 'canceled'

  // ── Onboarding ─────────────────────────────────────────────────────────────
  onboardingCompleted Boolean @default(false)
  market              String?
  goal                String?

  // ── Préférences ─────────────────────────────────────────────────────────────
  currency           String  @default("USD")
  currencyRate       Float   @default(1)
  startingCapital    Float   @default(0)
  notificationsEmail Boolean @default(true)
  debriefAutomatic   Boolean @default(true)

  // ── Profil stratégie ─────────────────────────────────────────────────────
  tradingStyle        String?
  tradingStrategy     String[]
  tradingSessions     String[]
  tradesPerDayMin     Int?
  tradesPerDayMax     Int?
  strategyDescription String?

  // ── Actifs tradés ────────────────────────────────────────────────────────
  tradingAssets String[]  // configurés dans les paramètres
  favoriteAsset String?   // pré-sélectionné dans la saisie rapide

  // ── Parrainage ambassadeur ────────────────────────────────────────────────
  referralCode String?  @unique  // code de parrainage unique
  referredBy   String?           // code de l'ambassadeur qui a référé cet user

  // ── Calendrier économique ─────────────────────────────────────────────────
  // Format : "EventName:Currency" — pin permanent (ex: "Non-Farm Payrolls:USD")
  pinnedEcoEvents String[]

  // ── Discord ──────────────────────────────────────────────────────────────────
  discordId String? @unique

  trades        Trade[]
  debriefs      WeeklyDebrief[]
  aiUsageLogs   AiUsageLog[]
  tradeSessions TradeSession[]
  dailyRecaps   DailyRecap[]
  referrals     ReferralCommission[] @relation("AmbassadorCommissions")
  lastSeenAt    DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ReferralCommission {
  id             String   @id @default(cuid())
  ambassadorId   String
  referredUserId String
  amount         Float
  subscriptionId String
  period         String
  status         String   @default("pending")
  createdAt      DateTime @default(now())

  ambassador User @relation("AmbassadorCommissions", fields: [ambassadorId], references: [id])

  @@unique([subscriptionId, period])
  @@index([ambassadorId])
}

model Trade {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset      String
  side       TradeSide
  entry      Float
  exit       Float?
  stopLoss   Float?
  takeProfit Float?
  pnl        Float?
  commission Float?
  riskReward Float?
  quantity        Float?
  capitalEngaged  Float?
  emotion    EmotionState
  setup      SetupType
  session    TradingSession
  timeframe  String
  notes      String?
  tags       String[]
  sessionId    String?
  tradeSession TradeSession? @relation(fields: [sessionId], references: [id])
  tradedAt     DateTime      @default(now())
  createdAt    DateTime      @default(now())

  @@index([userId, tradedAt])
  @@index([userId, emotion])
  @@index([userId, setup])
  @@index([sessionId])
}

model WeeklyDebrief {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekNumber  Int
  year        Int
  startDate   DateTime
  endDate     DateTime
  aiSummary   String
  insights    Json
  objectives  Json
  stats       Json
  generatedAt DateTime @default(now())

  @@unique([userId, weekNumber, year])
  @@index([userId, year, weekNumber])
}

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  feature      String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([feature])
}

// ── V2 Session Mode ─────────────────────────────────────────────────────────

model TradeSession {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  moodStart   MoodState?
  moodEnd     MoodState?
  totalPnl    Float?
  totalTrades Int           @default(0)
  winRate     Float?
  status      SessionStatus @default(ACTIVE)
  notes              String?
  reflectionNote     String?
  reflectionQuestion String?
  planNote           String?
  marketContext      String?
  maxDrawdown        Float?
  bestTradePnl       Float?
  bestTradeAsset     String?
  trades             Trade[]
  createdAt          DateTime      @default(now())

  @@index([userId, startedAt])
  @@index([userId, status])
}

model DailyRecap {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  tradesCount     Int      @default(0)
  pnl             Float    @default(0)
  winRate         Float    @default(0)
  dominantEmotion String?
  aiOneLiner      String?
  generatedAt     DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model EcoCalendarCache {
  id          String   @id @default(cuid())
  date        DateTime
  rawData     Json
  aiAnalysis  Json
  generatedAt DateTime @default(now())

  @@unique([date])
  @@index([date])
}

enum MoodState {
  CONFIDENT
  FOCUSED
  NEUTRAL
  TIRED
  STRESSED
}

enum SessionStatus {
  ACTIVE
  CLOSED
}


// ── Idempotence webhooks Stripe ─────────────────────────────────────────────
model StripeEvent {
  id          String   @id // Stripe event ID (evt_...)
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

enum Role {
  ADMIN
  USER
  BETA_TESTER
  AMBASSADOR
}

enum Plan {
  FREE
  STARTER
  PREMIUM
}

enum TradeSide {
  LONG
  SHORT
}

enum EmotionState {
  CONFIDENT
  STRESSED
  REVENGE
  FEAR
  FOCUSED
  NEUTRAL
}

enum SetupType {
  BREAKOUT
  PULLBACK
  RANGE
  REVERSAL
  SCALPING
  NEWS
}

enum TradingSession {
  LONDON
  NEW_YORK
  ASIAN
}

model EcoEvent {
  id         String   @id @default(cuid())
  date       String
  time       String
  name       String
  country    String
  currency   String
  impact     String
  actual     Float?
  estimate   Float?
  previous   Float?
  isReleased Boolean  @default(false)
  unit       String?
  fetchedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, name, currency])
  @@index([date])
  @@index([date, isReleased])
}

model EmailCampaignLog {
  id           String   @id @default(cuid())
  type         String
  subject      String?
  sentBy       String
  targetCount  Int
  successCount Int      @default(0)
  errorCount   Int      @default(0)
  sentAt       DateTime @default(now())

  @@index([type, sentAt])
}
