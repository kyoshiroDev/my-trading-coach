generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  name        String?
  role        Role      @default(USER)
  plan        Plan      @default(FREE)
  trialEndsAt DateTime?
  trialUsed   Boolean   @default(false)

  // ── Reset mot de passe ──────────────────────────────────────────────────
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?

  // ── Stripe ──────────────────────────────────────
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  stripePriceId            String?
  stripeInterval           String? // 'month' | 'year'
  stripeCurrentPeriodEnd   DateTime?
  stripeSubscriptionStatus String? // 'active' | 'trialing' | 'past_due' | 'unpaid' | 'canceled'
  subscriptionCanceledAt   DateTime? // date de résiliation (churn fiable) ; remis à null au réabonnement

  // Compte vitrine en lecture seule (démo landing). Bloque les écritures
  // (DemoReadOnlyGuard) et est exclu de toutes les métriques/crons/emails admin.
  isDemo Boolean @default(false)

  // ── Onboarding ─────────────────────────────────────────────────────────────
  onboardingCompleted Boolean @default(false)
  market              String?
  goal                String?

  // ── Préférences ─────────────────────────────────────────────────────────────
  currency           String  @default("USD")
  currencyRate       Float   @default(1)
  startingCapital    Float   @default(0)
  notificationsEmail Boolean @default(true)
  debriefAutomatic   Boolean @default(true)

  // ── Profil stratégie ─────────────────────────────────────────────────────
  tradingStyle        String?
  tradingStrategy     String[]
  tradingSessions     String[]
  tradesPerDayMin     Int?
  tradesPerDayMax     Int?
  strategyDescription String?

  // ── Actifs tradés ────────────────────────────────────────────────────────
  tradingAssets String[] // configurés dans les paramètres
  favoriteAsset String? // pré-sélectionné dans la saisie rapide

  // ── Parrainage ambassadeur ────────────────────────────────────────────────
  referralCode String? @unique // code de parrainage unique
  referredBy   String? // code de l'ambassadeur qui a référé cet user

  // ── Calendrier économique ─────────────────────────────────────────────────
  // Sélection d'annonces du JOUR (rituel de prep). Format : "EventName:Currency".
  // Réinitialisée chaque jour : si pinnedEcoDate ≠ aujourd'hui (Europe/Paris), la
  // lecture renvoie une sélection vide (reset paresseux, sans cron).
  pinnedEcoEvents String[]
  pinnedEcoDate   String? // YYYY-MM-DD (Europe/Paris) — jour de la sélection

  // ── Discord ──────────────────────────────────────────────────────────────────
  discordId String? @unique

  trades          Trade[]
  debriefs        WeeklyDebrief[]
  aiUsageLogs     AiUsageLog[]
  tradeSessions   TradeSession[]
  tradingAccounts TradingAccount[]
  dailyRecaps     DailyRecap[]
  dailyActivity   UserDailyActivity[]
  referrals       ReferralCommission[] @relation("AmbassadorCommissions")
  lastSeenAt      DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model ReferralCommission {
  id             String   @id @default(cuid())
  ambassadorId   String
  referredUserId String
  amount         Float
  subscriptionId String
  period         String
  status         String   @default("pending")
  createdAt      DateTime @default(now())

  ambassador User @relation("AmbassadorCommissions", fields: [ambassadorId], references: [id])

  @@unique([subscriptionId, period])
  @@index([ambassadorId])
}

model Trade {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset          String
  side           TradeSide
  entry          Float
  exit           Float?
  stopLoss       Float?
  takeProfit     Float?
  pnl            Float?
  commission     Float?
  riskReward     Float?
  quantity       Float?
  capitalEngaged Float?
  emotion        EmotionState
  setup          SetupType
  session        TradingSession
  timeframe      String
  notes          String?
  tags           String[]
  sessionId      String?
  tradeSession   TradeSession?   @relation(fields: [sessionId], references: [id])
  accountId      String?
  account        TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  tradedAt       DateTime        @default(now())
  createdAt      DateTime        @default(now())

  @@index([userId, tradedAt])
  @@index([userId, emotion])
  @@index([userId, setup])
  @@index([sessionId])
  @@index([accountId])
}

model WeeklyDebrief {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekNumber  Int
  year        Int
  startDate   DateTime
  endDate     DateTime
  aiSummary   String
  insights    Json
  objectives  Json
  stats       Json
  generatedAt DateTime @default(now())

  @@unique([userId, weekNumber, year])
  @@index([userId, year, weekNumber])
}

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  feature      String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([feature])
}

// ── V2 Session Mode ─────────────────────────────────────────────────────────

model TradeSession {
  id                 String          @id @default(cuid())
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt          DateTime        @default(now())
  endedAt            DateTime?
  moodStart          MoodState?
  moodEnd            MoodState?
  totalPnl           Float?
  totalTrades        Int             @default(0)
  winRate            Float?
  status             SessionStatus   @default(ACTIVE)
  notes              String?
  reflectionNote     String?
  reflectionQuestion String?
  planNote           String?
  marketContext      String?
  maxDrawdown        Float?
  bestTradePnl       Float?
  bestTradeAsset     String?
  accountId          String?
  account            TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  trades             Trade[]
  createdAt          DateTime        @default(now())

  @@index([userId, startedAt])
  @@index([userId, status])
  @@index([accountId])
}

// ── Multi-comptes (prop firms + perso) ──────────────────────────────────────
model TradingAccount {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  label           String // "Apex 50k #1"
  broker          String? // prop firm / courtier
  type            AccountType    @default(PERSONAL)
  status          AccountStatus  @default(ACTIVE)
  accountSize     Float?
  currency        String         @default("USD")
  // Règles prop firm (saisies par l'user, propres à sa firm/plan) :
  startingBalance Float? // base du solde (défaut = accountSize si null)
  profitTarget    Float? // objectif (eval) / objectif payout (funded), en $
  maxDrawdown     Float? // montant du drawdown autorisé, en $
  drawdownType    DrawdownType   @default(STATIC)
  trades          Trade[]
  tradeSessions   TradeSession[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, status])
}

model DailyRecap {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  tradesCount     Int      @default(0)
  pnl             Float    @default(0)
  winRate         Float    @default(0)
  dominantEmotion String?
  aiOneLiner      String?
  generatedAt     DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model EcoCalendarCache {
  id          String   @id @default(cuid())
  date        DateTime
  rawData     Json
  aiAnalysis  Json
  generatedAt DateTime @default(now())

  @@unique([date])
  @@index([date])
}

/// Analyse IA du calendrier éco mutualisée par (date, signature d'actifs).
/// 1 appel IA par signature partagé entre tous les users → coût O(actifs) au lieu de O(users).
model EcoAnalysisCache {
  id           String   @id @default(cuid())
  date         String // YYYY-MM-DD Paris
  assetsKey    String // signature normalisée des actifs
  analysisJson String   @db.Text
  createdAt    DateTime @default(now())

  @@unique([date, assetsKey])
  @@index([date])
}

enum MoodState {
  CONFIDENT
  FOCUSED
  NEUTRAL
  TIRED
  STRESSED
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

// ── Multi-comptes (prop firms + perso) ──────────────────────────────────────
enum AccountType {
  EVALUATION
  FUNDED
  PERSONAL
  DEMO
}

enum AccountStatus {
  ACTIVE
  PASSED
  FAILED
  ARCHIVED
}

enum DrawdownType {
  STATIC
  TRAILING
}

// ── Idempotence webhooks Stripe ─────────────────────────────────────────────
model StripeEvent {
  id          String   @id // Stripe event ID (evt_...)
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

enum Role {
  ADMIN
  USER
  BETA_TESTER
  AMBASSADOR
}

enum Plan {
  FREE
  STARTER
  PREMIUM
}

enum TradeSide {
  LONG
  SHORT
}

enum EmotionState {
  CONFIDENT
  STRESSED
  REVENGE
  FEAR
  FOCUSED
  NEUTRAL
}

enum SetupType {
  BREAKOUT
  PULLBACK
  RANGE
  REVERSAL
  SCALPING
  NEWS
}

enum TradingSession {
  LONDON
  NEW_YORK
  ASIAN
}

model EcoEvent {
  id         String   @id @default(cuid())
  date       String
  time       String
  name       String
  country    String
  currency   String
  impact     String
  actual     Float?
  estimate   Float?
  previous   Float?
  isReleased Boolean  @default(false)
  unit       String?
  nameFr     String? // libellé traduit une seule fois
  fetchedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, name, currency])
  @@index([date])
  @@index([date, isReleased])
}

model MarketNews {
  id            String   @id @default(cuid())
  url           String   @unique // clé de dédup (un article = une URL)
  symbol        String
  title         String // titre original
  titleFr       String? // traduit une seule fois
  text          String?  @db.Text
  textFr        String?  @db.Text
  sentiment     String? // bull | bear | neutral
  image         String?
  site          String?
  publishedDate DateTime
  translated    Boolean  @default(false)
  fetchedAt     DateTime @default(now())

  @@index([symbol, publishedDate])
  @@index([translated])
}

model EmailCampaignLog {
  id           String   @id @default(cuid())
  type         String
  subject      String?
  sentBy       String
  targetCount  Int
  successCount Int      @default(0)
  errorCount   Int      @default(0)
  sentAt       DateTime @default(now())

  @@index([type, sentAt])
}

// Historique quotidien des métriques clés (1 ligne/jour) → courbes d'évolution admin.
model MetricsSnapshot {
  id           String   @id @default(cuid())
  date         String   @unique // YYYY-MM-DD Paris (1 snapshot/jour)
  mrr          Int
  arr          Int
  totalUsers   Int
  freeUsers    Int
  starterUsers Int
  premiumUsers Int
  trials       Int
  newThisDay   Int // inscriptions du jour (24h glissantes)
  activeUsers  Int // users avec ≥1 trade sur 7 jours
  betaTesters  Int
  ambassadors  Int
  createdAt    DateTime @default(now())

  @@index([date])
}

/// Un jour d'activité par utilisateur (≥1 requête authentifiée dans la journée).
/// Alimente la heatmap « Connexions par jour » de la fiche admin. RGPD : userId + date
/// seulement, suppression en cascade avec le compte.
model UserDailyActivity {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date

  @@unique([userId, date])
  @@index([userId, date])
}

/// Trace analytique d'un compte supprimé (RGPD). Identité (name/email)
/// conservée 90 jours puis anonymisée par cron ; les champs analytiques restent.
model DeletedAccount {
  id           String    @id @default(cuid())
  name         String? // anonymisé après 90 j
  email        String? // anonymisé après 90 j
  signedUpAt   DateTime
  deletedAt    DateTime  @default(now())
  lifetimeDays Int
  plan         Plan
  hadTraded    Boolean
  tradesCount  Int
  referredBy   String?
  deletedBy    String // "self" | "admin"
  reason       String?
  anonymizedAt DateTime?

  @@index([deletedAt])
  @@index([anonymizedAt])
}
