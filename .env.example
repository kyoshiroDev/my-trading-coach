# ════════════════════════════════════════════════════════════════════
#  MyTradingCoach — API NestJS — exemple d'environnement (dev local)
#  Copier en `.env`. ⚠️ Placeholders uniquement, ne jamais commiter de vraie valeur.
#  Les variables marquées [CRITIQUE] sont validées au boot (REQUIRED_ENV_VARS / main.ts) :
#  l'API refuse de démarrer si l'une manque.
# ════════════════════════════════════════════════════════════════════

# ─── Base de données ───────────────────────────────────────────────────────────
# docker-compose.local.yml expose postgres sur :5432 et pgbouncer sur :6432
# DATABASE_URL [CRITIQUE] → pgbouncer (même config que prod)
# DATABASE_DIRECT_URL → postgres direct (utilisé par Prisma migrate en local)
DATABASE_URL=postgresql://mtc_user:devpassword@localhost:6432/mytradingcoach?pgbouncer=true&connection_limit=1
DATABASE_DIRECT_URL=postgresql://mtc_user:devpassword@localhost:5432/mytradingcoach
POSTGRES_USER=mtc_user
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=mytradingcoach

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_64_chars_random_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx          # [CRITIQUE]
JWT_REFRESH_SECRET=change_me_64_chars_different_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxx      # [CRITIQUE]
JWT_EXPIRES_IN=15m

# ─── Redis (cache + BullMQ) ──────────────────────────────────────────────────────
# Le code lit REDIS_HOST (défaut: localhost) et REDIS_PORT. En PROD, REDIS_HOST est
# OBLIGATOIRE (nom du service réseau), sinon connexion sur localhost = échec.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=devredispass
REDIS_URL=redis://:devredispass@localhost:6379

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                                                            # [CRITIQUE]

# ─── Mail (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                                                                   # [CRITIQUE]
MAIL_FROM=noreply@mytradingcoach.app
MAIL_SAV=support@mytradingcoach.app

# ─── Stripe ──────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...                                                           # [CRITIQUE]
STRIPE_WEBHOOK_SECRET=whsec_...                                                         # [CRITIQUE]
STRIPE_STARTER_PRICE_MONTHLY=price_...                                                  # [CRITIQUE]
STRIPE_STARTER_PRICE_YEARLY=price_...                                                   # [CRITIQUE]
# Premium en _V2 (migration de prix : les anciens IDs non-V2 ne sont plus utilisés)
STRIPE_PREMIUM_PRICE_MONTHLY_V2=price_...                                               # [CRITIQUE]
STRIPE_PREMIUM_PRICE_YEARLY_V2=price_...                                                # [CRITIQUE]
# STRIPE_PUBLIC_KEY=pk_test_... # Frontend uniquement — non utilisé par NestJS

# ─── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_BOT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ROLE_MEMBRE_ID=
DISCORD_ROLE_PREMIUM_ID=
DISCORD_INVITE_LINK=https://discord.gg/zSPD9pv4eB

# ─── FMP — Financial Modeling Prep (calendrier éco + news + recherche actifs) ──
# Plan Starter requis — https://site.financialmodelingprep.com/pricing-plans
FMP_API_KEY=

# ─── App / runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development          # 'production' active l'IA (eco/import) ; sinon coupée
PORT=3000
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,http://localhost:4321
IS_CRON_WORKER=false          # true uniquement sur l'instance worker (crons)
NEWS_TRANSLATION=true         # traduction IA des news (Premium)

# ─── Optionnels / contexte ───────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy
# PUPPETEER_EXECUTABLE_PATH=  # chemin Chromium pour l'export PDF (selon l'image Docker)
# BACKUP_DIR=/opt/backups     # répertoire des backups BDD (module admin/vps)

# ─── VPS (module admin : déploiement / backups via SSH) ──────────────────────────
# VPS_HOST=
# VPS_USER=
# VPS_SSH_KEY_B64=            # clé SSH privée encodée en base64
