# ─── Base de données ───────────────────────────────────────────────────────────
# En local : les deux pointent vers Postgres directement (pas de PgBouncer)
# En prod  : DATABASE_URL → pgbouncer:6432 (?pgbouncer=true&connection_limit=1)
#            DATABASE_DIRECT_URL → postgres:5432 (utilisé par les migrations Prisma)
DATABASE_URL=postgresql://mtc_user:devpassword@localhost:5432/mytradingcoach_dev
DATABASE_DIRECT_URL=postgresql://mtc_user:devpassword@localhost:5432/mytradingcoach_dev
POSTGRES_USER=mtc_user
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=mytradingcoach

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_64_chars_random_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_64_chars_different_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=15m

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:devredispass@localhost:6379
REDIS_PASSWORD=devredispass

# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Mail (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
MAIL_FROM=noreply@mytradingcoach.app
MAIL_SAV=support@mytradingcoach.app

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLIC_KEY=pk_test_... # Frontend uniquement — non utilisé par NestJS

# ─── Monitoring (optionnel) ────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,http://localhost:4321
