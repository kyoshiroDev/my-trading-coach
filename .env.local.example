# ─── Utilisé par le container API dans docker-compose.local.yml ───────────────
# Copier vers .env.local et remplir les vraies valeurs
# Les hostnames sont les noms des containers Docker (réseau interne mtc_local)

# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mtc_user:devpassword@mtc_pgbouncer_local:5432/mytradingcoach?pgbouncer=true&connection_limit=1
DATABASE_DIRECT_URL=postgresql://mtc_user:devpassword@mtc_postgres_local:5432/mytradingcoach
POSTGRES_USER=mtc_user
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=mytradingcoach

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_64_chars_random_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_64_chars_different_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=15m

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:devredispass@mtc_redis_local:6379
REDIS_PASSWORD=devredispass

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Mail (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
MAIL_FROM=noreply@mytradingcoach.app
MAIL_SAV=support@mytradingcoach.app

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_BOT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ROLE_MEMBRE_ID=
DISCORD_ROLE_PREMIUM_ID=
DISCORD_INVITE_LINK=https://discord.gg/zSPD9pv4eB

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200